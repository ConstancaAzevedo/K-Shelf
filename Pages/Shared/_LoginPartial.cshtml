@using Microsoft.AspNetCore.Identity
@using K_Shelf.Models
@inject SignInManager<Utilizador> SignInManager
@inject UserManager<Utilizador> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <!-- link para a pagina de gestao de conta -->
        <li class="nav-item">
            <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                <!-- icone do utilizador -->
                <img src="~/imagens/user.png" class="icon-white-img" alt="User" style="width: 18px; height: 18px; object-fit: contain; margin-right: 6px;" />
                Perfil do @User.Identity?.Name
            </a>
        </li>
        <!-- botao de logout -->
        <li class="nav-item">
            <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })" onsubmit="return confirmarLogout()">
                @Html.AntiForgeryToken() <!-- token de seguranca contra csrf -->
                <button type="submit" class="nav-link btn btn-link text-white d-flex align-items-center gap-1"
                        style="border: none; background: none; cursor: pointer; padding: 0.5rem 1rem;">
                    <!-- icone de logout -->
                    <img src="~/imagens/logout.png" class="icon-white-img" alt="Logout" style="width: 18px; height: 18px; object-fit: contain;" />
                    Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <!-- link para a pagina de registo -->
        <li class="nav-item">
            <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Register">
                <!-- icone de registo -->
                <img src="~/imagens/registar.png" class="icon-white-img" alt="Registar" style="width: 18px; height: 18px; object-fit: contain; margin-right: 4px;" />
                Registar
            </a>
        </li>
        <!-- link para a pagina de login -->
        <li class="nav-item">
            <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Login">
                <!-- icone de login -->
                <img src="~/imagens/login.png" class="icon-white-img" alt="Login" style="width: 18px; height: 18px; object-fit: contain; margin-right: 4px;" />
                Login
            </a>
        </li>
    }
</ul>

<!-- funcao javascript que mostra uma confirmacao antes de fazer logout -->
<script>
    function confirmarLogout() {
        return confirm('Tem a certeza que pretende terminar a sessão?');
    }
</script>

<!-- estilos para inverter as cores dos icones (ficam brancos para combinar com a navbar) -->
<style>
    .icon-white-img {
        width: 18px;
        height: 18px;
        object-fit: contain;
        filter: invert(1) brightness(100);
        flex-shrink: 0;
    }
</style>