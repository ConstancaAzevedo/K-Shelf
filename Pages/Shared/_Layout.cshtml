<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - K-Shelf</title>

    <!-- favicon da aplicacao -->
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />

    <!-- folhas de estilo -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/k-shelf.css" asp-append-version="true" /> <!-- estilos personalizados -->
</head>
<body>
    <!-- barra de navegacao principal -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-k-shelf">
        <div class="container">
            <!-- logo e nome da aplicacao -->
            <a class="navbar-brand d-flex align-items-center" asp-page="/Index">
                <img src="~/imagens/logosemfundo.png" alt="K-Shelf Logo" class="logo-k-shelf me-2" />
                <span class="fw-bold fs-4">K-Shelf</span>
            </a>

            <!-- botao para colapsar o menu em ecras pequenos -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- menu de navegacao -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <!-- menu para utilizadores nao autenticados (visitantes) -->
                    @if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <li class="nav-item"><a class="nav-link" asp-page="/Info">Informações</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Artistas/Index">Artistas</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Albuns/Index">Álbuns</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Binder/Catalogo">Photocards</a></li>
                    }

                    <!-- menu para utilizadores autenticados -->
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <!-- indicador de utilizadores online (apenas em ecras maiores) -->
                        <span class="badge rounded-pill ms-2 d-none d-sm-inline-block animate-fade-in" style="font-size: 0.75rem; background-color: rgba(46, 204, 113, 0.15) !important; border: 1px solid rgba(46, 204, 113, 0.3); color: #2ecc71; padding: 6px 12px;" title="Colecionadores online neste momento">
                            🟢 <span id="online-count-val">0</span> Online
                        </span>

                        <!-- links comuns a todos os utilizadores autenticados -->
                        <li class="nav-item"><a class="nav-link" asp-page="/Info">Informações</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Artistas/Index">Artistas</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Albuns/Index">Álbuns</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Binder/Catalogo">Photocards</a></li>

                        <!-- link especifico para utilizadores com role "user" -->
                        @if (User.IsInRole("User"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-page="/Colecoes/Index">Minhas Coleções</a></li>
                        }

                        <!-- link especifico para utilizadores com role "admin" -->
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Admin/Dashboard">
                                    Administração
                                </a>
                            </li>
                        }

                        <!-- link para o chat global -->
                        <li class="nav-item"><a class="nav-link" asp-page="/Chat">Chat K-Pop</a></li>

                    }
                </ul>
                <!-- partial com os botoes de login/logout e gestao de conta -->
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <!-- conteudo principal da pagina -->
    <div class="main-content">
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody() <!-- renderiza o conteudo especifico de cada pagina -->
            </main>
        </div>
    </div>

    <!-- rodape da pagina -->
    <footer class="footer-k-shelf">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    &copy; 2026 - K-Shelf - Plataforma de Gestão de Coleções de Kpop
                </div>
                <div class="col-md-6 text-end">
                    <a asp-page="/Info">Informações</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- bootstrap (necessario para os componentes interativos) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- jquery (necessario para validacoes e algumas funcionalidades) -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

    <!-- signalr para comunicacao em tempo real -->
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/dist/browser/signalr.min.js"></script>

    <!-- script que atualiza o contador de utilizadores online na navbar -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        // so inicializa a ligacao global se nao estivermos na pagina de chat
        // (evita abrir duas ligacoes simultaneas ao mesmo hub no mesmo ecra)
        if (window.location.pathname.toLowerCase().indexOf("/chat") === -1) {
        const conn = new signalR.HubConnectionBuilder()
        .withUrl("/kpopChatHub") // endpoint do hub
        .withAutomaticReconnect() // tenta reconectar automaticamente
        .build();

        // recebe o contador de utilizadores online
        conn.on("UpdateOnlineCount", function (count) {
        const el = document.getElementById("online-count-val");
        if (el) el.textContent = count;
        });

        // inicia a ligacao
        conn.start().catch(err => console.warn("SignalR Contador: " + err));
        }
        });
    </script>

    <!-- script de notificacoes em tempo real (toasts) -->
    <script src="~/js/notificacoes.js" asp-append-version="true"></script>

    <!-- scripts especificos de cada pagina (renderizados a partir da view) -->
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>