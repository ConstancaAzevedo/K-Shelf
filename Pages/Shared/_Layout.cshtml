<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - K-Shelf</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/k-shelf.css" /> <!-- nosso próprio css -->
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-k-shelf">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" asp-page="/Index">
                <img src="~/imagens/logosemfundo.png" alt="K-Shelf Logo" class="logo-k-shelf me-2" />
                <span class="fw-bold fs-4">K-Shelf</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-page="/Index">Início</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Artistas/Index">Artistas</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Albuns/Index">Álbuns</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Colecoes/Index">Coleções</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Info">Informações</a></li>
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <!-- CONTEÚDO PRINCIPAL -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="footer-k-shelf">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    &copy; 2025 - K-Shelf - Plataforma de Gestão de Coleções de Kpop
                </div>
                <div class="col-md-6 text-end">
                    <a asp-page="/Privacy">Privacidade</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>