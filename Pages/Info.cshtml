@page
@{
    ViewData["Title"] = "Informações do Projeto";
}

<div class="container py-4 animate-fade-in-up">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Cabeçalho -->
            <div class="glass-panel p-5 shadow-sm mb-4 text-center">
                <h1 class="title-kpop display-4 fw-bold mb-2">K-Shelf</h1>
                <p class="lead text-secondary">Plataforma de Gestão de Coleções de K-Pop</p>
                <hr class="my-4" />
                <p class="text-muted">Informações do Projeto</p>
            </div>

            <!-- Informações Acadêmicas -->
            <div class="glass-panel p-4 shadow-sm mb-4">
                <h3 class="fw-bold mb-3">Informações Acadêmicas</h3>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <p class="text-secondary small mb-1"><strong>Curso:</strong></p>
                        <p class="fw-bold">Licenciatura em Engenharia Informática</p>
                    </div>
                    <div class="col-md-6">
                        <p class="text-secondary small mb-1"><strong>Disciplina:</strong></p>
                        <p class="fw-bold">Desenvolvimento Web</p>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <p class="text-secondary small mb-1"><strong>Ano Letivo:</strong></p>
                        <p class="fw-bold">2025/2026</p>
                    </div>
                    <div class="col-md-6">
                        <p class="text-secondary small mb-1"><strong>Semestre:</strong></p>
                        <p class="fw-bold">2º Semestre</p>
                    </div>
                </div>
            </div>

            <!-- Autores -->
            <div class="glass-panel p-4 shadow-sm mb-4">
                <h3 class="fw-bold mb-3">Autores do Trabalho</h3>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3">
                            <p class="text-secondary small mb-1"><strong>Autor 1:</strong></p>
                            <p class="fw-bold mb-1">Constança Reis Ribeiro Lopes de Azevedo</p>
                            <p class="text-muted small">Nº 25969</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3">
                            <p class="text-secondary small mb-1"><strong>Autor 2:</strong></p>
                            <p class="fw-bold mb-1">Rui Miguel Gonçalves Dias</p>
                            <p class="text-muted small">Nº 25957</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tecnologias Utilizadas -->
            <div class="glass-panel p-4 shadow-sm mb-4">
                <h3 class="fw-bold mb-3">Tecnologias e Frameworks Utilizados</h3>

                <h6 class="fw-bold mt-3 mb-2">Backend & Framework:</h6>
                <div class="d-flex gap-2 flex-wrap mb-3">
                    <span class="badge-neon-pink">.NET 10.0</span>
                    <span class="badge-neon-pink">ASP.NET Core 10.0</span>
                    <span class="badge-neon-pink">Razor Pages</span>
                    <span class="badge-neon-pink">MVC (API Controllers)</span>
                </div>

                <h6 class="fw-bold mt-3 mb-2">Persistência de Dados:</h6>
                <div class="d-flex gap-2 flex-wrap mb-3">
                    <span class="badge-neon-purple">Entity Framework Core 10.0</span>
                    <span class="badge-neon-purple">LINQ</span>
                    <span class="badge-neon-purple">SQL Server (LocalDB)</span>
                </div>

                <h6 class="fw-bold mt-3 mb-2">Autenticação & Autorização:</h6>
                <div class="d-flex gap-2 flex-wrap mb-3">
                    <span class="badge-neon-success">ASP.NET Core Identity</span>
                    <span class="badge-neon-success">Role-Based Access Control (RBAC)</span>
                </div>

                <h6 class="fw-bold mt-3 mb-2">Comunicação em Tempo Real:</h6>
                <div class="d-flex gap-2 flex-wrap mb-3">
                    <span class="badge bg-warning text-dark">ASP.NET Core SignalR</span>
                    <span class="badge bg-warning text-dark">WebSockets</span>
                </div>

                <h6 class="fw-bold mt-3 mb-2">Frontend & UI:</h6>
                <div class="d-flex gap-2 flex-wrap mb-3">
                    <span class="badge bg-info text-white">Bootstrap 5.3.0</span>
                    <span class="badge bg-info text-white">HTML5</span>
                    <span class="badge bg-info text-white">CSS3 Customizado</span>
                    <span class="badge bg-info text-white">JavaScript</span>
                    <span class="badge bg-info text-white">jQuery</span>
                </div>

                <h6 class="fw-bold mt-3 mb-2">Ferramentas de Desenvolvimento:</h6>
                <div class="d-flex gap-2 flex-wrap mb-4">
                    <span class="badge bg-secondary">Visual Studio 2022 / 2026</span>
                    <span class="badge bg-secondary">Visual Studio Code</span>
                    <span class="badge bg-secondary">Git & GitHub</span>
                </div>

                <!-- Bibliotecas de Terceiros e Origens -->
                <h5 class="fw-bold mt-4 mb-3">Identificação das Bibliotecas de Terceiros & Origens</h5>
                <div class="table-responsive bg-light p-3 rounded-3 border mb-0" style="border-color: rgba(0,0,0,0.05) !important;">
                    <table class="table table-borderless table-sm mb-0 align-middle" style="font-size: 0.85rem;">
                        <thead>
                            <tr class="text-secondary border-bottom" style="border-color: rgba(0,0,0,0.05) !important;">
                                <th class="pb-2">Biblioteca / Recurso</th>
                                <th class="pb-2">Origem / Website</th>
                                <th class="pb-2">Método de Obtenção</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="fw-bold pt-2">Bootstrap (v5.3.0)</td>
                                <td class="pt-2"><a href="https://getbootstrap.com" target="_blank" class="text-decoration-none" style="color: var(--kpop-pink);">getbootstrap.com</a></td>
                                <td class="pt-2 text-muted">Carregado via CDN (jsDelivr)</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">jQuery (v3.6.0)</td>
                                <td><a href="https://jquery.com" target="_blank" class="text-decoration-none" style="color: var(--kpop-pink);">jquery.com</a></td>
                                <td class="text-muted">Incluído localmente (/lib/jquery)</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">jQuery Validation</td>
                                <td><a href="https://jqueryvalidation.org" target="_blank" class="text-decoration-none" style="color: var(--kpop-pink);">jqueryvalidation.org</a></td>
                                <td class="text-muted">Carregado localmente via scripts de validação</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Entity Framework Core</td>
                                <td><a href="https://nuget.org/packages/Microsoft.EntityFrameworkCore" target="_blank" class="text-decoration-none" style="color: var(--kpop-pink);">nuget.org</a></td>
                                <td class="text-muted">Instalado via NuGet Package Manager</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">ASP.NET Identity UI</td>
                                <td><a href="https://nuget.org/packages/Microsoft.AspNetCore.Identity.UI" target="_blank" class="text-decoration-none" style="color: var(--kpop-pink);">nuget.org</a></td>
                                <td class="text-muted">Instalado via NuGet Package Manager</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Swashbuckle (Swagger)</td>
                                <td><a href="https://github.com/domaindrivendev/Swashbuckle.AspNetCore" target="_blank" class="text-decoration-none" style="color: var(--kpop-pink);">github.com</a></td>
                                <td class="text-muted">Instalado via NuGet Package Manager</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Microsoft SignalR Client (v8.0.0)</td>
                                <td><a href="https://cdnjs.com/libraries/microsoft-signalr" target="_blank" class="text-decoration-none" style="color: var(--kpop-pink);">cdnjs.com</a></td>
                                <td class="text-muted">Carregado via CDN oficial (jsDelivr)</td>
                            </tr>
                            <tr>
                                <td class="fw-bold pb-2">Google Fonts (Outfit)</td>
                                <td class="pb-2"><a href="https://fonts.google.com" target="_blank" class="text-decoration-none" style="color: var(--kpop-pink);">fonts.google.com</a></td>
                                <td class="pb-2 text-muted">Carregado dinamicamente via Web API do Google</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Credenciais de Acesso -->
            <div class="glass-panel p-4 shadow-sm mb-4">
                <h3 class="fw-bold mb-3">Credenciais de Acesso</h3>

                <div class="alert alert-warning rounded-3 mb-3">
                    <strong>Utilizador Teste (Admin):</strong>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3">
                            <p class="text-secondary small mb-1"><strong>Email:</strong></p>
                            <p class="fw-bold font-monospace">admin@kshelf.com</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3">
                            <p class="text-secondary small mb-1"><strong>Password:</strong></p>
                            <p class="fw-bold font-monospace">Admin@123</p>
                        </div>
                    </div>
                </div>

                <div class="mt-3 p-3 bg-light rounded-3">
                    <p class="text-secondary small mb-1"><strong>Nível de Acesso:</strong></p>
                    <p class="mb-0"><span class="badge-neon-pink">Admin</span> — Acesso total à gestão de Artistas, Álbuns e Coleções</p>
                </div>

                <div class="alert alert-info rounded-3 mt-3 mb-0">
                    <small><strong>Nota:</strong> Para registar um novo utilizador comum (User), use a página de Registo. Utilizadores comuns têm acesso apenas às suas próprias coleções.</small>
                </div>
            </div>

            <!-- Funcionalidades Implementadas -->
            <div class="glass-panel p-4 shadow-sm mb-4">
                <h3 class="fw-bold mb-3">Funcionalidades Implementadas</h3>

                <h6 class="fw-bold mt-3 mb-2">Componente 1 - Interface Web (60%):</h6>
                <ul class="list-unstyled mb-3">
                    <li class="mb-2"><span class="badge-neon-pink">✓</span> CRUD completo de Artistas</li>
                    <li class="mb-2"><span class="badge-neon-pink">✓</span> CRUD completo de Álbuns com gestão de faixas</li>
                    <li class="mb-2"><span class="badge-neon-pink">✓</span> CRUD completo de Coleções com adicionar/remover álbuns</li>
                    <li class="mb-2"><span class="badge-neon-pink">✓</span> CRUD completo de Photocards (painel de administração)</li>
                    <li class="mb-2"><span class="badge-neon-pink">✓</span> Catálogo Geral de Photocards com pesquisa e filtro por grupo</li>
                    <li class="mb-2"><span class="badge-neon-pink">✓</span> Dossiê Virtual de Photocards (Binder pessoal) com grelha 3×3 e efeito 3D Flip</li>
                    <li class="mb-2"><span class="badge-neon-pink">✓</span> Autenticação e autorização com roles (Admin/User)</li>
                    <li class="mb-2"><span class="badge-neon-pink">✓</span> Interface responsiva em Português</li>
                    <li class="mb-2"><span class="badge-neon-pink">✓</span> Validação de formulários</li>
                </ul>

                <h6 class="fw-bold mt-3 mb-2">Componente 2 - API (30%):</h6>
                <ul class="list-unstyled mb-3">
                    <li class="mb-2"><span class="badge-neon-purple">✓</span> API REST com CRUD completo para Artistas, Álbuns, Coleções e Photocards</li>
                    <li class="mb-2"><span class="badge-neon-purple">✓</span> Documentação interativa Swagger/OpenAPI configurada e ativa em /swagger</li>
                </ul>

                <h6 class="fw-bold mt-3 mb-2">Comunicação em Tempo Real (SignalR):</h6>
                <ul class="list-unstyled mb-3">
                    <li class="mb-2"><span class="badge-neon-pink">✓</span> Chat Global de Colecionadores em tempo real</li>
                    <li class="mb-2"><span class="badge-neon-pink">✓</span> Contador global de utilizadores online em tempo real na Navbar</li>
                </ul>

                <h6 class="fw-bold mt-3 mb-2">Componente 3 - Publicação (10%):</h6>
                <ul class="list-unstyled">
                    <li class="mb-2"><span class="badge bg-secondary">⏳</span> Pendente</li>
                </ul>
            </div>

            <!-- Notas Adicionais -->
            <div class="glass-panel p-4 shadow-sm">
                <h3 class="fw-bold mb-3">Notas Adicionais</h3>

                <div class="alert alert-light rounded-3 mb-2">
                    <p class="mb-1"><strong>Base de Dados:</strong></p>
                    <small>SQL Server com Entity Framework Core. Tabelas: Artistas, Álbuns, Coleções, Grupos, Solistas, Músicas, Photocards, UtilizadorPhotocards e relacionamentos obrigatórios (many-to-one: Artista → Grupo; many-to-many: Utilizador ↔ Photocards via UtilizadorPhotocards).</small>
                </div>

                <div class="alert alert-light rounded-3 mb-2">
                    <p class="mb-1"><strong>Código Limpo:</strong></p>
                    <small>Código formatado e comentado conforme exigências. Referências a bibliotecas de terceiros incluídas nos comentários e nesta página.</small>
                </div>

                <div class="alert alert-light rounded-3">
                    <p class="mb-1"><strong>Repositório GitHub:</strong></p>
                    <small><a href="https://github.com/ConstancaAzevedo/K-Shelf" target="_blank" class="alert-link">https://github.com/ConstancaAzevedo/K-Shelf</a></small>
                </div>
            </div>

            <!-- Botão Voltar -->
            <div class="mt-4 text-center">
                <a asp-page="/Index" class="btn btn-kpop rounded-pill px-4">← Voltar ao Início</a>
            </div>
        </div>
    </div>
</div>
