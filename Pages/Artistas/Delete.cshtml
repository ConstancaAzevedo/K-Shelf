@page
@model K_Shelf.Pages.Artistas.DeleteModel
@{
    ViewData["Title"] = "Eliminar Artista";
}

<div class="container mt-4 animate-fade-in-up">

    <!-- mensagens de feedback -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["WarningMessage"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show rounded-3" role="alert">
            @TempData["WarningMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-danger text-white">
                    <h2 class="mb-0">@ViewData["Title"]</h2>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <h4 class="mb-2">Tem a certeza que pretende eliminar este artista?</h4>
                        <p class="mb-0">Esta ação é irreversível!</p>
                    </div>

                    <div class="mb-4">
                        @if (!string.IsNullOrEmpty(Model.Artista?.ImagemUrl))
                        {
                            <img src="@Model.Artista.ImagemUrl" style="max-height: 150px; border-radius: 10px;" />
                        }
                    </div>

                    <dl class="row">
                        <dt class="col-sm-3">Nome</dt>
                        <dd class="col-sm-9">@Model.Artista?.Nome</dd>

                        <dt class="col-sm-3">Nome Artístico</dt>
                        <dd class="col-sm-9">@(Model.Artista?.NomeArtistico ?? "N/A")</dd>

                        <dt class="col-sm-3">Posição</dt>
                        <dd class="col-sm-9">@(Model.Artista?.Posicao ?? "N/A")</dd>

                        <dt class="col-sm-3">Pais</dt>
                        <dd class="col-sm-9">@(Model.Artista?.Pais ?? "N/A")</dd>

                        <dt class="col-sm-3">Data Nascimento</dt>
                        <dd class="col-sm-9">@(Model.Artista?.DataNascimento.ToString("dd/MM/yyyy") ?? "N/A")</dd>

                        <dt class="col-sm-3">Ativo</dt>
                        <dd class="col-sm-9">@(Model.Artista?.IsAtivo == true ? "Sim" : "Não")</dd>
                    </dl>

                    <form method="post">
                        <input type="hidden" asp-for="Artista.Id" />
                        <button type="submit" class="btn btn-danger">Confirmar Eliminação</button>
                        <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>