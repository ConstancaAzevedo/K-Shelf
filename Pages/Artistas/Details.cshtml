@page
@model K_Shelf.Pages.Artistas.DetailsModel
@{
    ViewData["Title"] = Model.Artista?.NomeExibicao ?? "Detalhes do Artista";
}

<div class="container py-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
                @if (!string.IsNullOrEmpty(Model.Artista?.ImagemUrl))
                {
                    <img src="@Model.Artista.ImagemUrl" class="card-img-top" alt="@Model.Artista.NomeExibicao" style="object-fit: cover; height: 400px;">
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, var(--kpop-pink), var(--kpop-purple)); height: 400px;">
                        <span class="display-1">🎤</span>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="display-5 fw-bold">@Model.Artista?.NomeExibicao</h1>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="mb-3">
                            <a asp-page="./Edit" asp-route-id="@Model.Artista?.Id" class="btn btn-warning">✏️ Editar</a>
                            <a asp-page="./Delete" asp-route-id="@Model.Artista?.Id" class="btn btn-danger">🗑️ Eliminar</a>
                        </div>
                    }

                    <hr />

                    <div class="row">
                        <div class="col-md-6">
                            <h5>📋 Informação Pessoal</h5>
                            <dl class="row">
                                <dt class="col-sm-4">Nome</dt>
                                <dd class="col-sm-8">@Model.Artista?.Nome</dd>

                                <dt class="col-sm-4">Nome Artístico</dt>
                                <dd class="col-sm-8">@(Model.Artista?.NomeArtistico ?? "N/A")</dd>

                                <dt class="col-sm-4">Data Nascimento</dt>
                                <dd class="col-sm-8">@(Model.Artista?.DataNascimento.ToString("dd/MM/yyyy") ?? "N/A")</dd>

                                <dt class="col-sm-4">Idade</dt>
                                <dd class="col-sm-8">@(Model.Artista?.Idade) anos</dd>

                                <dt class="col-sm-4">Nacionalidade</dt>
                                <dd class="col-sm-8">@(Model.Artista?.Nacionalidade ?? "N/A")</dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <h5>🎤 Carreira</h5>
                            <dl class="row">
                                <dt class="col-sm-4">Posição</dt>
                                <dd class="col-sm-8">@(Model.Artista?.Posicao ?? "N/A")</dd>

                                <dt class="col-sm-4">Grupo</dt>
                                <dd class="col-sm-8">@(Model.Artista?.Grupo?.Nome ?? "N/A")</dd>

                                <dt class="col-sm-4">Data Entrada</dt>
                                <dd class="col-sm-8">@(Model.Artista?.DataEntrada?.ToString("dd/MM/yyyy") ?? "N/A")</dd>

                                <dt class="col-sm-4">Data Saída</dt>
                                <dd class="col-sm-8">@(Model.Artista?.DataSaida?.ToString("dd/MM/yyyy") ?? "N/A")</dd>

                                <dt class="col-sm-4">Status</dt>
                                <dd class="col-sm-8">
                                    @if (Model.Artista?.IsAtivo == true)
                                    {
                                        <span class="badge-neon-success">Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inativo</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <div class="mt-3">
                        <a asp-page="./Index" class="btn btn-secondary">← Voltar para Lista</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>