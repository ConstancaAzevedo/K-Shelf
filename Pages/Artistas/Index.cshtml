@page
@model ArtistasIndexModel
@{
    ViewData["Title"] = "Artistas K-Pop";
}

<div class="container py-4">

    <!-- mensagens de feedback -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 animate-fade-in-up" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 animate-fade-in-up" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["WarningMessage"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show rounded-3 animate-fade-in-up" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["WarningMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row align-items-center mb-5">
        <div class="col-lg-6">
            <h1 class="display-4 fw-bold">Artistas</h1>
            @if (User.IsInRole("Admin"))
            {
                <a asp-page="./Create" class="btn btn-primary mt-2">➕ Adicionar Artista</a>
            }
        </div>
        <div class="col-lg-6">
            <div class="p-4 d-flex justify-content-around text-center shadow-sm rounded">
                <div>
                    <h3 class="fw-bold mb-0">@Model.TotalArtists</h3>
                    <small>Total Artistas</small>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <!-- Barra de Pesquisa -->
    <div class="p-4 mb-5 shadow-sm rounded bg-light">
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Pesquisar artista..." />
            </div>
            <div class="col-md-3">
                <select name="TypeFilter" class="form-select">
                    <option value="all" selected="@(Model.TypeFilter == "all")">Todos</option>
                    <option value="groups" selected="@(Model.TypeFilter == "groups")">Membros de Grupos</option>
                    <option value="solos" selected="@(Model.TypeFilter == "solos")">Solistas</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary">Filtrar</button>
                <a asp-page="./Index" class="btn btn-secondary">Limpar</a>
            </div>
        </form>
    </div>

    <!-- Lista de Artistas -->
    @if (!Model.Artistas.Any())
    {
        <div class="text-center py-5">
            <h3>Nenhum artista encontrado</h3>
            <a asp-page="./Create" class="btn btn-primary">Adicionar Artista</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var artista in Model.Artistas)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(artista.ImagemUrl))
                        {
                            <img src="@artista.ImagemUrl" class="card-img-top" alt="@artista.NomeExibicao" style="height: 250px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-secondary d-flex align-items-center justify-content-center" style="height: 250px;">
                                <span class="display-1">🎤</span>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@artista.NomeExibicao</h5>
                            <p class="card-text">
                                <strong>Posição:</strong> @(artista.Posicao ?? "N/A")<br />
                                <strong>Pais:</strong> @(artista.Pais ?? "N/A")
                            </p>
                        </div>
                        <div class="card-footer">
                            <a asp-page="./Details" asp-route-id="@artista.Id" class="btn btn-info btn-sm">Detalhes</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-page="./Edit" asp-route-id="@artista.Id" class="btn btn-warning btn-sm">Editar</a>
                                <a asp-page="./Delete" asp-route-id="@artista.Id" class="btn btn-danger btn-sm">Eliminar</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>