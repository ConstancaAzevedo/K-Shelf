@page
@model K_Shelf.Pages.Artistas.IndexModel
@{
    ViewData["Title"] = "Artistas K-Pop";
}

<div class="container py-4 animate-fade-in-up">
    <!-- Cabeçalho -->
    <div class="row align-items-center mb-5">
        <div class="col-lg-6">
            <h1 class="title-kpop display-4 fw-bold">Artistas</h1>
            <p class="text-secondary lead">Explore os seus idols favoritos, solistas talentosos e membros de grupos lendários.</p>
        </div>
        <!-- Estatísticas Glass -->
        <div class="col-lg-6">
            <div class="glass-panel p-4 d-flex justify-content-around text-center shadow-sm">
                <div>
                    <h3 class="fw-bold text-dark mb-0">@Model.TotalArtists</h3>
                    <small class="text-secondary uppercase-tracking">Total Idols</small>
                </div>
                <div class="border-start border-end px-4">
                    <h3 class="fw-bold text-dark mb-0">@Model.TotalGroups</h3>
                    <small class="text-secondary">Grupos</small>
                </div>
                <div>
                    <h3 class="fw-bold text-dark mb-0">@Model.TotalSolos</h3>
                    <small class="text-secondary">Solistas</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Barra de Pesquisa e Filtros -->
    <div class="glass-panel p-4 mb-5 shadow-sm">
        <form method="get" class="row g-3 align-items-center">
            <!-- Barra de Pesquisa -->
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 rounded-start-pill text-secondary ps-3">
                        🔍
                    </span>
                    <input type="text" asp-for="SearchTerm" class="form-control border-start-0 rounded-end-pill search-input-kpop" placeholder="Pesquisar por nome, nacionalidade ou posição..." />
                </div>
            </div>

            <!-- Filtros Tipo -->
            <div class="col-md-5">
                <div class="d-flex gap-2 justify-content-md-start">
                    <button type="submit" name="TypeFilter" value="all" class="filter-btn-kpop @(Model.TypeFilter == "all" ? "active" : "")">
                        Todos
                    </button>
                    <button type="submit" name="TypeFilter" value="groups" class="filter-btn-kpop @(Model.TypeFilter == "groups" ? "active" : "")">
                        Grupos
                    </button>
                    <button type="submit" name="TypeFilter" value="solos" class="filter-btn-kpop @(Model.TypeFilter == "solos" ? "active" : "")">
                        Solistas
                    </button>
                </div>
            </div>

            <!-- Botão Limpar -->
            <div class="col-md-2 text-md-end">
                @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.TypeFilter != "all")
                {
                    <a asp-page="./Index" class="btn btn-link text-decoration-none text-secondary fw-semibold">
                        Limpar Filtros
                    </a>
                }
            </div>
        </form>
    </div>

    <!-- Grelha de Artistas -->
    @if (!Model.Artistas.Any())
    {
        <div class="text-center py-5 glass-panel shadow-sm">
            <span class="display-3">🎤</span>
            <h3 class="mt-3 fw-bold">Nenhum artista encontrado</h3>
            <p class="text-secondary">Tente mudar o termo de pesquisa ou os filtros selecionados.</p>
            <a asp-page="./Index" class="btn btn-kpop mt-3">Ver Todos os Artistas</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var artista in Model.Artistas)
            {
                <div class="col">
                    <div class="card artist-card h-100 shadow-sm">
                        <!-- Imagem -->
                        <div class="artist-image-wrapper">
                            @if (!string.IsNullOrEmpty(artista.ImagemUrl))
                            {
                                <img src="@artista.ImagemUrl" class="artist-image" alt="@artista.NomeExibicao" />
                            }
                            else
                            {
                                <!-- Fallback elegante se não houver imagem -->
                                <div class="artist-image d-flex align-items-center justify-content-center text-white" style="background: linear-gradient(135deg, var(--kpop-pink), var(--kpop-purple)); font-size: 4rem;">
                                    🎤
                                </div>
                            }
                            
                            <!-- Overlay de Gradiente com Badges de Tipo -->
                            <div class="artist-overlay">
                                @if (artista.GrupoId.HasValue)
                                {
                                    <span class="badge bg-light text-dark shadow-sm mb-2 rounded-pill px-3">
                                        👥 @artista.Grupo?.Nome
                                    </span>
                                }
                                @if (artista.SolistaId.HasValue)
                                {
                                    <span class="badge bg-dark text-white shadow-sm mb-2 rounded-pill px-3 border border-secondary">
                                        ✨ Solista
                                    </span>
                                }
                                <h4 class="fw-bold mb-0 text-white">@artista.NomeArtistico</h4>
                                <small style="opacity: 0.85;">@artista.Nome</small>
                            </div>
                        </div>

                        <!-- Detalhes do Cartão -->
                        <div class="card-body d-flex flex-column justify-content-between p-4">
                            <div>
                                <!-- Posição e Nacionalidade -->
                                <div class="mb-3">
                                    <p class="card-text text-secondary mb-1">
                                        <strong>Posição:</strong> @(artista.Posicao ?? "N/A")
                                    </p>
                                    <p class="card-text text-secondary mb-1">
                                        <strong>Nacionalidade:</strong> @(artista.Nacionalidade ?? "N/A")
                                    </p>
                                    <p class="card-text text-secondary mb-0">
                                        <strong>Idade:</strong> @artista.Idade anos (@artista.DataNascimento.ToString("dd/MM/yyyy"))
                                    </p>
                                </div>
                            </div>

                            <!-- Rodapé do Cartão -->
                            <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                <div>
                                    @if (artista.IsAtivo)
                                    {
                                        <span class="badge-neon-success">Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary text-white rounded-pill px-3">Inativo</span>
                                    }
                                </div>
                                <a href="#" class="btn btn-sm btn-kpop rounded-pill px-3 py-1">Ver Perfil</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
