@page
@model K_Shelf.Pages.Grupos.EditModel
@{
    ViewData["Title"] = "Editar Grupo";
}

<div class="container py-4 animate-fade-in-up">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- painel principal com efeito glassmorphism -->
            <div class="glass-panel p-4 shadow-sm">
                <!-- cabecalho com icone e titulo -->
                <div class="d-flex align-items-center mb-4">
                    <span class="fs-1 me-3">✏️</span> <!-- icone de edicao -->
                    <div>
                        <h2 class="fw-bold mb-0">Editar Grupo</h2>
                        <!-- mostra o nome do grupo que esta a ser editado -->
                        <p class="text-secondary mb-0">@Model.Grupo.Nome</p>
                    </div>
                </div>

                <!-- formulario de edicao -->
                <form method="post">
                    <!-- campo escondido para enviar o id do grupo -->
                    <input type="hidden" asp-for="Grupo.Id" />
                    <!-- resumo de erros de validacao -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>

                    <!-- campo do nome (obrigatorio) -->
                    <div class="mb-3">
                        <label asp-for="Grupo.Nome" class="form-label fw-bold">
                            Nome <span class="text-danger">*</span> <!-- asterisco indica campo obrigatorio -->
                        </label>
                        <input asp-for="Grupo.Nome" class="form-control search-input-kpop" />
                        <span asp-validation-for="Grupo.Nome" class="text-danger small"></span>
                    </div>

                    <!-- campo da data de estreia (obrigatorio) -->
                    <div class="mb-3">
                        <label asp-for="Grupo.DataEstreia" class="form-label fw-bold">
                            Data de Estreia <span class="text-danger">*</span>
                        </label>
                        <!-- input do tipo date para selecionar uma data -->
                        <input asp-for="Grupo.DataEstreia" type="date" class="form-control search-input-kpop" />
                        <span asp-validation-for="Grupo.DataEstreia" class="text-danger small"></span>
                    </div>

                    <!-- campo da companhia (opcional) -->
                    <div class="mb-3">
                        <label asp-for="Grupo.Companhia" class="form-label fw-bold">Companhia</label>
                        <input asp-for="Grupo.Companhia" class="form-control search-input-kpop" />
                        <span asp-validation-for="Grupo.Companhia" class="text-danger small"></span>
                    </div>

                    <!-- campo do fansigno (opcional) -->
                    <div class="mb-3">
                        <label asp-for="Grupo.Fansigno" class="form-label fw-bold">Fansigno</label>
                        <input asp-for="Grupo.Fansigno" class="form-control search-input-kpop" />
                        <span asp-validation-for="Grupo.Fansigno" class="text-danger small"></span>
                    </div>

                    <!-- campo da url da imagem (opcional) -->
                    <div class="mb-3">
                        <label asp-for="Grupo.ImagemUrl" class="form-label fw-bold">URL da Imagem</label>
                        <input asp-for="Grupo.ImagemUrl" class="form-control search-input-kpop" placeholder="https://..." />
                        <span asp-validation-for="Grupo.ImagemUrl" class="text-danger small"></span>
                    </div>

                    <!-- checkbox para indicar se o grupo esta ativo -->
                    <div class="mb-3 form-check">
                        <input asp-for="Grupo.IsAtivo" class="form-check-input" />
                        <label asp-for="Grupo.IsAtivo" class="form-check-label fw-bold">Ativo</label>
                    </div>

                    <!-- botoes de acao -->
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-kpop px-4">💾 Guardar</button> <!-- botao de submit -->
                        <a asp-page="./Index" class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a> <!-- volta para a lista -->
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- scripts de validacao do lado do cliente -->
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}