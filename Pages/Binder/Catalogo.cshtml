@page
@model K_Shelf.Pages.Binder.CatalogoModel
@{
    ViewData["Title"] = "Catálogo de Photocards";
}

<!-- Mensagens de Feedback -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 animate-fade-in-up" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 animate-fade-in-up" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container py-4 animate-fade-in-up">
    <!-- Cabeçalho -->
    <div class="row align-items-center mb-5">
        <div class="col-lg-7">
            <h1 class="title-kpop display-4 fw-bold">Catálogo de Photocards</h1>
            <p class="text-secondary lead">Explore a base de dados oficial de photocards do K-Shelf e adicione-os à sua coleção.</p>
        </div>
        <div class="col-lg-5 text-lg-end">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-page="./Index" class="btn btn-kpop rounded-pill px-4 py-2">📖 Ver O Meu Binder</a>
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-secondary rounded-pill px-4 py-2">Fazer login para colecionar</a>
            }
        </div>
    </div>

    <!-- Barra de Pesquisa e Filtros -->
    <div class="glass-panel p-4 mb-5 shadow-sm">
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-bold text-dark">Pesquisa</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 rounded-start-pill text-secondary ps-3">🔍</span>
                    <input type="text" asp-for="SearchQuery" class="form-control border-start-0 rounded-end-pill search-input-kpop" placeholder="Pesquisar por versão, artista ou álbum..." />
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-dark">Filtrar por Grupo</label>
                <select asp-for="GrupoFilter" class="form-select search-input-kpop rounded-pill" asp-items="Model.GruposSelectList">
                    <option value="">Todos os Grupos</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-kpop w-100 rounded-pill py-2">Filtrar</button>
                @if (!string.IsNullOrEmpty(Model.SearchQuery) || Model.GrupoFilter.HasValue)
                {
                    <a asp-page="./Catalogo" class="btn btn-outline-secondary rounded-circle px-3 py-2" title="Limpar Filtros">❌</a>
                }
            </div>
        </form>
    </div>

    <!-- Grelha de Photocards -->
    @if (Model.Photocards != null && Model.Photocards.Any())
    {
        <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-4">
            @foreach (var item in Model.Photocards)
            {
                <div class="col">
                    <div class="glass-panel p-2 shadow-sm text-center h-100 d-flex flex-column justify-content-between transition-hover" style="border-radius: 1.25rem;">
                        <div>
                            <!-- Imagem do Photocard -->
                            <div class="rounded-4 overflow-hidden shadow-sm mb-3 position-relative" style="aspect-ratio: 2.5/3.5; background: #eaeaea;">
                                <img src="@item.ImagemUrl" alt="@item.Versao" style="width: 100%; height: 100%; object-fit: cover;" />
                            </div>
                            
                            <!-- Metadados -->
                            <span class="badge-neon-pink mb-2 d-inline-block px-3 py-1 rounded-pill" style="font-size: 0.75rem;">
                                🎤 @(item.Artista?.NomeArtistico ?? "Artista")
                            </span>
                            <h6 class="fw-bold mb-1 text-dark text-truncate" title="@(item.Artista?.Grupo?.Nome ?? item.Artista?.Solista?.Nome ?? "Solista")">
                                @(item.Artista?.Grupo?.Nome ?? item.Artista?.Solista?.Nome ?? "Solista")
                            </h6>
                            <small class="text-secondary text-truncate d-block" title="@item.Versao">🎴 @item.Versao</small>
                            @if (item.Album != null)
                            {
                                <small class="text-secondary text-truncate d-block" title="@item.Album.Titulo">💿 @item.Album.Titulo</small>
                            }
                            else
                            {
                                <small class="text-secondary text-truncate d-block">💿 Outros / Merch</small>
                            }
                        </div>

                        <!-- Ações -->
                        <div class="mt-3">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <button type="button" class="btn btn-sm btn-kpop rounded-pill w-100 py-2" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#addBinderModal" 
                                        data-id="@item.Id" 
                                        data-title="@item.Versao" 
                                        data-artist="@(item.Artista?.NomeArtistico ?? "Artista")" 
                                        data-img="@item.ImagemUrl">
                                    + Colecionar
                                </button>
                            }
                            else
                            {
                                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-sm btn-outline-secondary rounded-pill w-100 py-2">
                                    Adicionar
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="glass-panel p-5 text-center text-secondary">
            <p style="font-size: 3rem;">🎴</p>
            <h4 class="fw-bold text-dark">Nenhum photocard encontrado</h4>
            <p class="mb-0">Tenta ajustar os termos da pesquisa ou escolhe outro artista.</p>
        </div>
    }
</div>

<!-- Modal de Adição ao Binder -->
<div class="modal fade" id="addBinderModal" tabindex="-1" aria-labelledby="addBinderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-panel text-dark" style="border: 1px solid rgba(255,255,255,0.4); background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(15px);">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="addBinderModalLabel">🎴 Adicionar ao Meu Binder</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Adicionar">
                <div class="modal-body">
                    <input type="hidden" id="modalPhotocardId" name="AddPhotocardId" />
                    
                    <div class="text-center mb-4">
                        <div class="rounded-4 overflow-hidden shadow-md mx-auto mb-2" style="width: 100px; height: 140px; background: #eee;">
                            <img id="modalPhotocardImg" src="" style="width:100%; height:100%; object-fit:cover;" />
                        </div>
                        <h6 id="modalPhotocardTitle" class="fw-bold mb-0 text-dark"></h6>
                        <small id="modalPhotocardArtist" class="badge bg-light border text-dark rounded-pill px-2 py-1 mt-1"></small>
                    </div>

                    <!-- Estado -->
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Onde guardar este card?</label>
                        <select name="AddEstado" class="form-select search-input-kpop rounded-pill" asp-items="Html.GetEnumSelectList<K_Shelf.Models.EstadoPhotocard>()"></select>
                    </div>

                    <!-- Quantidade -->
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Quantidade</label>
                        <input type="number" name="AddQuantidade" value="1" min="1" max="100" class="form-control search-input-kpop rounded-pill" />
                    </div>

                    <!-- Notas -->
                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark">Notas Pessoais</label>
                        <input type="text" name="AddNotas" class="form-control search-input-kpop rounded-pill" placeholder="Ex: Troco por RM, primeira tiragem, etc." />
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-3" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-kpop rounded-pill px-4">Adicionar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const addBinderModal = document.getElementById('addBinderModal');
        if (addBinderModal) {
            addBinderModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const id = button.getAttribute('data-id');
                const title = button.getAttribute('data-title');
                const artist = button.getAttribute('data-artist');
                const img = button.getAttribute('data-img');

                document.getElementById('modalPhotocardId').value = id;
                document.getElementById('modalPhotocardTitle').textContent = title;
                document.getElementById('modalPhotocardArtist').textContent = artist;
                document.getElementById('modalPhotocardImg').src = img;
            });
        }
    </script>
}
