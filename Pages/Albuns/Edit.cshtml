@page
@model K_Shelf.Pages.Albuns.EditModel
@{
    ViewData["Title"] = "Editar Álbum";
}

<div class="container py-4 animate-fade-in-up">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-panel p-4 shadow-sm">
                <div class="d-flex align-items-center mb-4">
                    <span class="fs-1 me-3">✏️</span>
                    <div>
                        <h2 class="fw-bold mb-0">Editar Álbum</h2>
                        <p class="text-secondary mb-0">@Model.Album.Titulo</p>
                    </div>
                </div>

                <form method="post">
                    <input type="hidden" asp-for="Album.Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>

                    <!-- Título (obrigatório) -->
                    <div class="mb-3">
                        <label asp-for="Album.Titulo" class="form-label fw-bold">
                            Título <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Album.Titulo" class="form-control search-input-kpop" placeholder="Ex: Map of the Soul: 7" />
                        <span asp-validation-for="Album.Titulo" class="text-danger small"></span>
                    </div>

                    <!-- Data de Lançamento (obrigatório) -->
                    <div class="mb-3">
                        <label asp-for="Album.DataLancamento" class="form-label fw-bold">
                            Data de Lançamento <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Album.DataLancamento" type="date" class="form-control search-input-kpop" />
                        <span asp-validation-for="Album.DataLancamento" class="text-danger small"></span>
                    </div>

                    <!-- URL da Capa (obrigatório) -->
                    <div class="mb-3">
                        <label asp-for="Album.CapaUrl" class="form-label fw-bold">
                            URL da Capa <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Album.CapaUrl" class="form-control search-input-kpop" placeholder="https://..." />
                        <span asp-validation-for="Album.CapaUrl" class="text-danger small"></span>
                    </div>

                    <!-- Tipo de Álbum (obrigatório) -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Album.Tipo" class="form-label fw-bold">
                                Tipo de Álbum <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Album.Tipo" class="form-select search-input-kpop"
                                    asp-items="Html.GetEnumSelectList<K_Shelf.Models.Album.TipoAlbum>()">
                            </select>
                            <span asp-validation-for="Album.Tipo" class="text-danger small"></span>
                        </div>

                        <!-- Edição (opcional) -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Album.Edicao" class="form-label fw-bold">Edição</label>
                            <select asp-for="Album.Edicao" class="form-select search-input-kpop"
                                    asp-items="Html.GetEnumSelectList<K_Shelf.Models.Album.EdicaoAlbum>()">
                            </select>
                            <span asp-validation-for="Album.Edicao" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="bg-light rounded-3 p-3 mb-4">
                        <h6 class="fw-bold mb-3">🎤 Artista</h6>
                        <p class="text-secondary small mb-3">Associe o álbum a um <strong>Grupo</strong> ou a um <strong>Solista</strong> (não pode ser ambos).</p>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Album.GrupoId" class="form-label fw-bold"></label>
                                <div class="d-flex gap-2">
                                    <select asp-for="Album.GrupoId" class="form-select search-input-kpop"
                                            asp-items="Model.GruposSelectList">
                                        <option value="">-- Nenhum Grupo --</option>
                                    </select>
                                    <a asp-page="/Grupos/Create" class="btn btn-outline-primary btn-sm" target="_blank">➕</a>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Album.SolistaId" class="form-label fw-bold"></label>
                                <div class="d-flex gap-2">
                                    <select asp-for="Album.SolistaId" class="form-select search-input-kpop"
                                            asp-items="Model.SolistasSelectList">
                                        <option value="">-- Nenhum Solista --</option>
                                    </select>
                                    <a asp-page="/Solistas/Create" class="btn btn-outline-primary btn-sm" target="_blank">➕</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-light rounded-3 p-3 mb-4">
                        <h6 class="fw-bold mb-3">🎵 Músicas</h6>
                        <p class="text-secondary small mb-3">Adicione músicas a este álbum.</p>

                        <div class="row align-items-end">
                            <!-- Dropdown para selecionar música existente -->
                            <div class="col-md-5 mb-2">
                                <label class="form-label fw-bold">Adicionar Música Existente</label>
                                <select id="selectMusicaExistente" class="form-select search-input-kpop">
                                    <option value="">-- Selecione uma música --</option>
                                    @foreach (var musica in Model.AlbunsSelectList)
                                    {
                                        <option value="@musica.Value">@musica.Text</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3 mb-2">
                                <button type="button" class="btn btn-kpop w-100" id="btnAdicionarMusica">
                                    ➕ Adicionar
                                </button>
                            </div>
                            <div class="col-md-4 mb-2">
                                <a asp-page="/Musicas/Create" asp-route-albumId="@Model.Album.Id" class="btn btn-outline-primary w-100" target="_blank">
                                    ✨ Criar Nova Música
                                </a>
                            </div>
                        </div>

                        <!-- Lista de músicas atuais -->
                        <div class="mt-3">
                            <p class="fw-bold mb-2">Músicas neste álbum:</p>
                            <ul class="list-unstyled mb-0" id="listaMusicasAtuais">
                                @if (Model.Album.Musicas != null && Model.Album.Musicas.Any())
                                {
                                    @foreach (var musica in Model.Album.Musicas)
                                    {
                                        <li class="d-flex justify-content-between align-items-center py-1 border-bottom border-light" data-musica-id="@musica.Id">
                                            <span>@musica.TrackNumber. @musica.Titulo</span>
                                            <button type="button" class="btn btn-sm btn-outline-danger btn-remover-musica" data-musica-id="@musica.Id">
                                                ✕
                                            </button>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <p class="text-secondary small">Nenhuma música associada a este álbum.</p>
                                }
                            </ul>
                        </div>
                    </div>


                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-kpop px-4">💾 Guardar Alterações</button>
                        <a asp-page="./Details" asp-route-id="@Model.Album.Id" class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const grupoSelect = document.getElementById('Album_GrupoId');
        const solistaSelect = document.getElementById('Album_SolistaId');

        grupoSelect.addEventListener('change', function () {
            if (this.value) solistaSelect.value = '';
        });

        solistaSelect.addEventListener('change', function () {
            if (this.value) grupoSelect.value = '';
        });
    </script>


    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            // ============================================================
            // Adicionar música ao álbum
            // ============================================================
            $('#btnAdicionarMusica').click(function () {
                var musicaId = $('#selectMusicaExistente').val();
                var albumId = @Model.Album.Id;

                if (!musicaId) {
                    alert('Selecione uma música para adicionar.');
                    return;
                }

                $.ajax({
                    url: '/api/Albuns/' + albumId + '/musicas/' + musicaId,
                    type: 'POST',
                    success: function () {
                        location.reload();
                    },
                    error: function (xhr) {
                        alert('Erro ao adicionar música: ' + xhr.responseText);
                    }
                });
            });

            // ============================================================
            // Remover música do álbum
            // ============================================================
            $('.btn-remover-musica').click(function () {
                var musicaId = $(this).data('musica-id');
                var albumId = @Model.Album.Id;

                if (!confirm('Tem a certeza que pretende remover esta música do álbum?')) {
                    return;
                }

                $.ajax({
                    url: '/api/Albuns/' + albumId + '/musicas/' + musicaId,
                    type: 'DELETE',
                    success: function () {
                        location.reload();
                    },
                    error: function (xhr) {
                        alert('Erro ao remover música: ' + xhr.responseText);
                    }
                });
            });
        });
    </script>
}
