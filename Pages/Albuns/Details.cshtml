@page
@model K_Shelf.Pages.Albuns.DetailsModel
@{
    ViewData["Title"] = Model.Album.Titulo;
}

<div class="container py-4 animate-fade-in-up">

    <!-- mensagem de sucesso -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- coluna esquerda: capa + acoes -->
        <div class="col-md-4">
            <div class="glass-panel p-3 shadow-sm text-center">
                <!-- efeito vinil -->
                <div class="vinyl-container-wrapper mx-auto mb-3" style="width: 220px; height: 220px;">
                    <div class="vinyl-album" style="width: 220px; height: 220px;">
                        @if (!string.IsNullOrEmpty(Model.Album.CapaUrl))
                        {
                            <img src="@Model.Album.CapaUrl" class="vinyl-album-cover" alt="@Model.Album.Titulo" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100 bg-secondary text-white" style="font-size: 4rem;">💿</div>
                        }
                    </div>
                    <div class="vinyl-disc" style="width: 200px; height: 200px;"></div>
                </div>

                <h3 class="fw-bold mt-3">@Model.Album.Titulo</h3> <!-- titulo do album -->

                <div class="d-flex gap-2 justify-content-center mb-3 flex-wrap">
                    <span class="badge-neon-pink">@Model.Album.Tipo</span> <!-- tipo do album -->
                    <span class="badge-neon-purple">@Model.Album.Edicao</span> <!-- edicao do album -->
                </div>

                <p class="text-secondary">📅 @Model.Album.DataLancamento.ToString("dd MMMM yyyy")</p> <!-- data de lancamento formatada -->
                @if (User.IsInRole("Admin"))
                {
                    <!-- botoes de acao para admin -->
                    <div class="d-flex flex-column gap-2 mt-3">
                        <a asp-page="./Edit" asp-route-id="@Model.Album.Id" class="btn btn-warning rounded-pill">✏️ Editar</a>
                        <a asp-page="./Delete" asp-route-id="@Model.Album.Id" class="btn btn-outline-danger rounded-pill">🗑️ Eliminar</a>
                    </div>
                }

                <div class="mt-3">
                    <a asp-page="./Index" class="btn btn-outline-secondary rounded-pill w-100">← Voltar</a> <!-- volta para a lista -->
                </div>
            </div>
        </div>

        <!-- coluna direita: informacoes + faixas -->
        <div class="col-md-8">
            <!-- artista -->
            <div class="glass-panel p-4 shadow-sm mb-4">
                <h5 class="fw-bold mb-3">🎤 Artista</h5>
                @if (Model.Album.Grupo != null)
                {
                    <!-- mostra o grupo -->
                    <div class="d-flex align-items-center gap-3">
                        @if (!string.IsNullOrEmpty(Model.Album.Grupo.ImagemUrl))
                        {
                            <img src="@Model.Album.Grupo.ImagemUrl" alt="@Model.Album.Grupo.Nome"
                                 style="width: 60px; height: 60px; object-fit: cover; border-radius: 50%;" />
                        }
                        <div>
                            <h5 class="mb-0 fw-bold">@Model.Album.Grupo.Nome</h5>
                            <small class="text-secondary">👥 Grupo • @Model.Album.Grupo.Artistas?.Count membros</small>
                        </div>
                    </div>
                }
                else if (Model.Album.Solista != null)
                {
                    <!-- mostra o solista -->
                    <div class="d-flex align-items-center gap-3">
                        @if (!string.IsNullOrEmpty(Model.Album.Solista.ImagemUrl))
                        {
                            <img src="@Model.Album.Solista.ImagemUrl" alt="@Model.Album.Solista.Nome"
                                 style="width: 60px; height: 60px; object-fit: cover; border-radius: 50%;" />
                        }
                        <div>
                            <h5 class="mb-0 fw-bold">@Model.Album.Solista.Nome</h5>
                            <small class="text-secondary">🎤 Solista</small>
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-secondary mb-0">Artista Independente</p>
                }
            </div>

            <!-- lista de faixas -->
            <div class="glass-panel p-4 shadow-sm mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">🎵 Faixas</h5>
                    <span class="badge bg-secondary rounded-pill">@(Model.Album.Musicas?.Count ?? 0) tracks</span> <!-- numero de musicas -->
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-page="/Musicas/Create" asp-route-albumId="@Model.Album.Id" class="btn btn-sm btn-kpop rounded-pill px-3 py-1">
                            ➕ Adicionar Música
                        </a>
                    }
                </div>

                @if (Model.Album.Musicas != null && Model.Album.Musicas.Any())
                {
                    <!-- accordion com as musicas -->
                    <div class="accordion" id="accordionMusicas">
                        @foreach (var musica in Model.Album.Musicas.OrderBy(m => m.TrackNumber)) // ordena por numero de faixa
                        {
                            <div class="accordion-item border-0 mb-2" style="background: rgba(0,0,0,0.02); border-radius: 12px; overflow: hidden;">

                                <h2 class="accordion-header" id="heading-@musica.Id">
                                    <div class="accordion-button collapsed d-flex align-items-center"
                                         style="cursor: default;">

                                        <span class="text-secondary me-2" style="min-width: 22px; font-size: 0.85rem; font-weight: 600; flex-shrink: 0;">@musica.TrackNumber.</span> <!-- numero da faixa -->
                                        @if (!string.IsNullOrEmpty(musica.PreviewAudioUrl))
                                        {
                                            <!-- botao de preview de audio -->
                                            <span class="btn-play-audio me-2"
                                                  data-audio-url="@musica.PreviewAudioUrl"
                                                  data-track-id="@musica.Id"
                                                  title="Ouvir Preview">
                                                <span class="play-icon">▶</span>
                                            </span>
                                            <div class="audio-wave-bars d-none me-2" id="wave-@musica.Id">
                                                <span></span><span></span><span></span>
                                            </div>
                                        }
                                        else
                                        {
                                            <span style="width: 28px; flex-shrink: 0;"></span>
                                        }

                                        <div style="flex: 1; min-width: 0; line-height: 1.2;">
                                            <span class="fw-bold">@musica.Titulo</span> <!-- titulo da musica -->
                                            <div class="d-flex gap-1 flex-wrap align-items-center mt-1">
                                                @if (musica.IsTitleTrack)
                                                {
                                                    <span class="badge-neon-pink" style="font-size: 0.65rem; padding: 2px 8px;">★ Title Track</span>
                                                }
                                                @if (musica.IsSingle)
                                                {
                                                    <span class="badge-neon-purple" style="font-size: 0.65rem; padding: 2px 8px;">Single</span>
                                                }
                                                <span class="text-secondary" style="font-size: 0.75rem;">⏱️ @musica.DuracaoFormatada</span> <!-- duracao formatada -->
                                            </div>
                                        </div>

                                        <!-- botao para ver detalhes -->
                                        <span class="btn-ver-detalhes text-secondary ms-auto"
                                              data-target="collapse-@musica.Id"
                                              title="Ver detalhes"
                                              style="cursor: pointer; font-size: 0.8rem; white-space: nowrap; padding: 4px 10px; border-radius: 20px; border: 1px solid rgba(0,0,0,0.1);">
                                            Ver detalhes <i class="bi bi-chevron-down track-chevron" style="font-size: 0.75rem;"></i>
                                        </span>

                                    </div>
                                </h2>

                                <!-- detalhes da musica (expandivel) -->
                                <div id="collapse-@musica.Id" class="accordion-collapse collapse"
                                     aria-labelledby="heading-@musica.Id">
                                    <div class="accordion-body px-3 pb-3 pt-2" style="background: rgba(0,0,0,0.03); border-top: 1px solid rgba(0,0,0,0.05);">
                                        @{
                                            bool temDetalhes = !string.IsNullOrEmpty(musica.Compositores)
                                                            || !string.IsNullOrEmpty(musica.Produtores)
                                                            || !string.IsNullOrEmpty(musica.Letra)
                                                            || !string.IsNullOrEmpty(musica.YoutubeUrl);
                                        }
                                        @if (!temDetalhes)
                                        {
                                            <p class="text-secondary small mb-0">Sem detalhes disponíveis.</p>
                                        }
                                        else
                                        {
                                            <div class="row g-3">
                                                @if (!string.IsNullOrEmpty(musica.Compositores))
                                                {
                                                    <div class="col-md-6">
                                                        <p class="text-secondary small mb-1"><strong>Compositores</strong></p>
                                                        <p class="mb-0 small">@musica.Compositores</p>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(musica.Produtores))
                                                {
                                                    <div class="col-md-6">
                                                        <p class="text-secondary small mb-1"><strong>Produtores</strong></p>
                                                        <p class="mb-0 small">@musica.Produtores</p>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(musica.Letra))
                                                {
                                                    <div class="col-12">
                                                        <p class="text-secondary small mb-1"><strong>Letra</strong></p>
                                                        <p class="mb-0 small" style="white-space: pre-wrap;">@musica.Letra</p>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrEmpty(musica.YoutubeUrl))
                                                {
                                                    <div class="col-12">
                                                        <a href="@musica.YoutubeUrl" target="_blank" class="btn btn-outline-danger btn-sm rounded-pill">
                                                            ▶️ Ver no YouTube
                                                        </a>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-secondary text-center py-3">Nenhuma música registada neste álbum.</p>
                }
            </div>

            <!-- colecoes onde aparece (apenas para utilizadores autenticados) -->
            @if (User.Identity?.IsAuthenticated == true && Model.Album.AlbumColecoes != null && Model.Album.AlbumColecoes.Any())
            {
                <div class="glass-panel p-4 shadow-sm">
                    <h5 class="fw-bold mb-3">📚 Presente nas Coleções</h5>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var ac in Model.Album.AlbumColecoes)
                        {
                            if (ac.Colecao != null)
                            {
                                <a asp-page="/Colecoes/Details" asp-route-id="@ac.ColecaoId"
                                   class="btn btn-outline-secondary rounded-pill btn-sm">
                                    📁 @ac.Colecao.Nome
                                </a>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- scripts do lado do cliente -->
@section Scripts {
    <style>
        /* estilos das ondas de audio */
        .audio-wave-bars {
            display: inline-flex;
            align-items: flex-end;
            gap: 2px;
            width: 14px;
            height: 14px;
            margin-right: 5px;
        }

            .audio-wave-bars span {
                display: inline-block;
                width: 2px;
                background-color: var(--kpop-pink);
                animation: bounceWave 0.8s ease-in-out infinite alternate;
                border-radius: 1px;
            }

                .audio-wave-bars span:nth-child(1) {
                    height: 4px;
                    animation-delay: -0.6s;
                }

                .audio-wave-bars span:nth-child(2) {
                    height: 10px;
                    animation-delay: -0.3s;
                }

                .audio-wave-bars span:nth-child(3) {
                    height: 6px;
                    animation-delay: 0s;
                }

        @keyframes bounceWave {
            0% {
                height: 2px;
            }

            100% {
                height: 14px;
            }
        }

        .accordion-button:not(.collapsed) .track-chevron {
            transform: rotate(180deg);
        }

        .accordion-button {
            display: flex !important;
            align-items: center !important;
            flex-wrap: nowrap !important;
            gap: 8px !important;
            padding: 10px 14px !important;
            box-shadow: none !important;
            background: transparent !important;
        }

        .track-chevron {
            flex-shrink: 0;
            font-size: 0.85rem;
            transition: transform 0.2s ease;
            margin-left: auto;
        }

        /* remove seta padrao do bootstrap */
        .accordion-button::after {
            display: none !important;
        }

        .accordion-button:not(.collapsed) {
            background: rgba(255, 107, 157, 0.08) !important;
            color: var(--kpop-pink) !important;
        }

        .accordion-button:focus {
            box-shadow: none !important;
            border-color: transparent !important;
        }

        .accordion-item {
            border: 1px solid rgba(0,0,0,0.05) !important;
            background: rgba(0,0,0,0.02);
        }

        /* botao de play */
        .btn-play-audio {
            flex-shrink: 0;
            width: 28px;
            height: 28px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            border: none;
            background: rgba(0,0,0,0.06) !important;
            font-size: 0.7rem;
            color: var(--bs-secondary) !important;
            cursor: pointer;
            transition: all 0.2s ease;
            padding: 0;
            outline: none;
        }

            .btn-play-audio:hover {
                color: var(--kpop-pink) !important;
                background: rgba(231, 76, 60, 0.1) !important;
                transform: scale(1.1);
            }

            .btn-play-audio.playing {
                color: #fff !important;
                background: var(--kpop-pink) !important;
            }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // controlo do audio
            let activeAudio = null;
            let activeBtn = null;
            let activeWave = null;

            // evento de play/pause
            document.querySelectorAll('.btn-play-audio').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const audioUrl = this.getAttribute('data-audio-url');
                    const trackId  = this.getAttribute('data-track-id');
                    const wave     = document.getElementById('wave-' + trackId);
                    const icon     = this.querySelector('.play-icon');

                    if (activeAudio && activeAudio.src.endsWith(encodeURI(audioUrl).replace(/%2F/g, '/')) || (activeAudio && activeAudio.src === audioUrl)) {
                        if (activeAudio.paused) {
                            activeAudio.play();
                            icon.innerText = '⏸';
                            btn.classList.add('playing');
                            if (wave) wave.classList.remove('d-none');
                        } else {
                            activeAudio.pause();
                            icon.innerText = '▶';
                            btn.classList.remove('playing');
                            if (wave) wave.classList.add('d-none');
                        }
                        return;
                    }

                    // para o audio anterior
                    if (activeAudio) {
                        activeAudio.pause();
                        if (activeBtn) {
                            activeBtn.querySelector('.play-icon').innerText = '▶';
                            activeBtn.classList.remove('playing');
                        }
                        if (activeWave) activeWave.classList.add('d-none');
                    }

                    activeAudio = new Audio(audioUrl);
                    activeBtn   = btn;
                    activeWave  = wave;

                    activeAudio.play().then(function () {
                        icon.innerText = '⏸';
                        btn.classList.add('playing');
                        if (wave) wave.classList.remove('d-none');
                    }).catch(function (e) {
                        console.error('Erro ao reproduzir:', e);
                        alert('Não foi possível carregar o preview de áudio.');
                    });

                    activeAudio.addEventListener('ended', function () {
                        icon.innerText = '▶';
                        btn.classList.remove('playing');
                        if (wave) wave.classList.add('d-none');
                        activeAudio = null;
                        activeBtn   = null;
                        activeWave  = null;
                    });
                });
            });

            // botao de ver detalhes
            document.querySelectorAll('.btn-ver-detalhes').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const targetId = this.getAttribute('data-target');
                    const collapse = document.getElementById(targetId);
                    const chevron  = this.querySelector('.track-chevron');
                    const isOpen   = collapse.classList.contains('show');

                    // fecha todos os outros
                    document.querySelectorAll('.accordion-collapse.show').forEach(function (el) {
                        el.classList.remove('show');
                    });
                    document.querySelectorAll('.btn-ver-detalhes').forEach(function (b) {
                        b.querySelector('.track-chevron').style.transform = '';
                        b.innerHTML = b.innerHTML.replace('Fechar', 'Ver detalhes');
                    });

                    if (!isOpen) {
                        collapse.classList.add('show');
                        chevron.style.transform = 'rotate(180deg)';
                        this.innerHTML = 'Fechar <i class="bi bi-chevron-up track-chevron" style="font-size: 0.75rem;"></i>';
                    }
                });
            });
        });
    </script>
}