@page
@model K_Shelf.Pages.Albuns.IndexModel
@using K_Shelf.Models
@{
    ViewData["Title"] = "Álbuns K-Pop";
}

<div class="container py-4 animate-fade-in-up">
    <!-- Cabeçalho -->
    <div class="row align-items-center mb-5">
        <div class="col-lg-6">
            <h1 class="title-kpop display-4 fw-bold">Álbuns</h1>
            <p class="text-secondary lead">Descubra os lançamentos mais recentes de K-Pop, edições físicas e faixas inesquecíveis!</p>
            @if (User.IsInRole("Admin"))
            {
                <a asp-page="./Create" class="btn btn-kpop mt-2 rounded-pill">Adicionar Álbum</a>
            }
        </div>
        <!-- Estatísticas Glass -->
        <div class="col-lg-6">
            <div class="glass-panel p-4 d-flex justify-content-around text-center shadow-sm">
                <div>
                    <h3 class="fw-bold text-dark mb-0">@Model.TotalAlbuns</h3>
                    <small class="text-secondary">Total Álbuns</small>
                </div>
                <div class="border-start border-end px-4">
                    <h3 class="fw-bold text-dark mb-0">@Model.StudioAlbunsCount</h3>
                    <small class="text-secondary">Estúdio</small>
                </div>
                <div>
                    <h3 class="fw-bold text-dark mb-0">@(Model.EpAlbunsCount + Model.SingleAlbunsCount)</h3>
                    <small class="text-secondary">EPs / Singles</small>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Barra de Pesquisa e Filtros -->
    <div class="glass-panel p-4 mb-5 shadow-sm">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label fw-bold text-dark">Pesquisa</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 rounded-start-pill text-secondary ps-3">🔍</span>
                    <input type="text" asp-for="SearchTerm" class="form-control border-start-0 rounded-end-pill search-input-kpop" placeholder="Nome do álbum, grupo ou solista..." />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-dark">Tipo de Álbum</label>
                <select asp-for="TypeFilter" class="form-select search-input-kpop rounded-pill" asp-items="Html.GetEnumSelectList<Album.TipoAlbum>()">
                    <option value="">Todos os Tipos</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-dark">Edição</label>
                <select asp-for="EditionFilter" class="form-select search-input-kpop rounded-pill" asp-items="Html.GetEnumSelectList<Album.EdicaoAlbum>()">
                    <option value="">Todas as Edições</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-kpop w-100 rounded-pill py-2">Filtrar</button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.TypeFilter.HasValue || Model.EditionFilter.HasValue)
                {
                    <a asp-page="./Index" class="btn btn-outline-secondary rounded-circle px-3 py-2" title="Limpar Filtros">❌</a>
                }
            </div>
        </form>
    </div>

    <!-- Grelha de Álbuns -->
    @if (!Model.Albuns.Any())
    {
        <div class="text-center py-5 glass-panel shadow-sm">
            <span class="display-3">📀</span>
            <h3 class="mt-3 fw-bold">Nenhum álbum encontrado</h3>
            <p class="text-secondary">Tente ajustar os critérios de pesquisa ou limpar os filtros</p>
            <a asp-page="./Index" class="btn btn-kpop mt-3">Ver Todos os Álbuns</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-5">
            @foreach (var album in Model.Albuns)
            {
                <div class="col">
                    <div class="glass-panel p-4 h-100 d-flex flex-column justify-content-between shadow-sm hover-elevate transition-all border-0">
                        <div>
                            <div class="vinyl-container-wrapper">
                                <div class="vinyl-album">
                                    <img src="@album.CapaUrl" class="vinyl-album-cover" alt="@album.Titulo" />
                                </div>
                                <div class="vinyl-disc"></div>
                            </div>

                            <div class="text-center mt-2">
                                <h3 class="fw-bold mb-1 fs-4 text-dark">@album.Titulo</h3>
                                <p class="text-secondary fw-semibold mb-2">
                                    👤
                                    @if (album.GrupoId.HasValue)
                                    {
                                        <span>@album.Grupo?.Nome</span>
                                    }
                                    else if (album.SolistaId.HasValue)
                                    {
                                        <span>@album.Solista?.Nome</span>
                                    }
                                    else
                                    {
                                        <span>Artista Independente</span>
                                    }
                                </p>
                                <div class="d-flex gap-2 justify-content-center flex-wrap mb-3">
                                    <span class="badge-neon-pink">@album.Tipo.ToString()</span>
                                    <span class="badge-neon-purple">@album.Edicao.ToString()</span>
                                </div>
                            </div>

                            <div class="album-tracks border-top pt-3 mt-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold text-dark mb-0">Faixas</h6>
                                    <span class="badge bg-secondary rounded-pill">@(album.Musicas?.Count ?? 0) tracks</span>
                                </div>
                                <ul class="list-unstyled mb-0" style="max-height: 140px; overflow-y: auto; font-size: 0.9rem;">
                                    @if (album.Musicas != null && album.Musicas.Any())
                                    {
                                        @foreach (var musica in album.Musicas.OrderBy(m => m.TrackNumber))
                                        {
                                            <li class="d-flex justify-content-between align-items-center py-1 border-bottom border-light">
                                                <span class="text-truncate ps-1">
                                                    @if (musica.IsTitleTrack)
                                                    {
                                                        <strong style="color: var(--kpop-pink);">★ @musica.TrackNumber. @musica.Titulo</strong>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-dark">@musica.TrackNumber. @musica.Titulo</span>
                                                    }
                                                </span>
                                                <small class="text-secondary text-end me-1">@musica.DuracaoFormatada</small>
                                            </li>
                                        }
                                    }
                                    else
                                    {
                                        <li class="text-secondary py-1 text-center">Nenhuma música encontrada</li>
                                    }
                                </ul>
                            </div>
                        </div>

                        <!-- Botões de Ação -->
                        <div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
                            <span class="text-secondary" style="font-size: 0.85rem;">
                                📅 @album.DataLancamento.ToString("dd MMM yyyy")
                            </span>
                            <div class="d-flex gap-2">
                                <a asp-page="./Details" asp-route-id="@album.Id" class="btn btn-sm btn-kpop rounded-pill px-3 py-1">Detalhes</a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-page="./Edit" asp-route-id="@album.Id" class="btn btn-sm btn-warning rounded-pill px-2 py-1">✏️</a>
                                    <a asp-page="./Delete" asp-route-id="@album.Id" class="btn btn-sm btn-outline-danger rounded-pill px-2 py-1">🗑️</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
