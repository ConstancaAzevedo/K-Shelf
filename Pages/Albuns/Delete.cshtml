@page
@model K_Shelf.Pages.Albuns.DeleteModel
@{
    ViewData["Title"] = "Eliminar Álbum";
}

<div class="container py-4 animate-fade-in-up">

    <!-- mensagens de feedback -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["WarningMessage"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show rounded-3" role="alert">
            @TempData["WarningMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="glass-panel p-4 shadow-sm">
                <!-- cabecalho com titulo de alerta -->
                <div class="d-flex align-items-center mb-4">
                    <div>
                        <h2 class="fw-bold mb-0 text-danger">Eliminar Álbum</h2> <!-- titulo em vermelho -->
                        <p class="text-secondary mb-0">Esta ação é irreversível</p> <!-- aviso de irreversibilidade -->
                    </div>
                </div>

                <!-- alerta de confirmacao de eliminacao -->
                <div class="alert alert-warning rounded-3 mb-4">
                    <h5 class="fw-bold mb-1">Tem a certeza que pretende eliminar este álbum?</h5>
                    @if (Model.ColecoesCont > 0)
                    {
                        <!-- aviso se o album estiver em colecoes -->
                        <p class="mb-0">Este álbum está presente em <strong>@Model.ColecoesCont coleção(ões)</strong> e será removido de todas elas.</p>
                    }
                    else
                    {
                        <!-- aviso sobre as musicas associadas -->
                        <p class="mb-0">Todas as músicas associadas também serão eliminadas.</p>
                    }
                </div>

                <!-- pre-visualizacao do album -->
                <div class="d-flex gap-4 align-items-center mb-4 p-3 bg-light rounded-3">
                    <!-- capa do album -->
                    @if (!string.IsNullOrEmpty(Model.Album.CapaUrl))
                    {
                        <img src="@Model.Album.CapaUrl" alt="@Model.Album.Titulo"
                             style="width: 100px; height: 100px; object-fit: cover; border-radius: 12px;" />
                    }
                    else
                    {
                        <!-- placeholder para album sem capa -->
                        <div class="d-flex align-items-center justify-content-center bg-secondary text-white"
                             style="width: 100px; height: 100px; border-radius: 12px; font-size: 2rem;">
                            💿
                        </div>
                    }
                    <div>
                        <h4 class="fw-bold mb-1">@Model.Album.Titulo</h4> <!-- titulo do album -->
                        <p class="text-secondary mb-1">
                            <!-- nome do grupo ou solista -->
                            @if (Model.Album.Grupo != null)
                            {
                                <span>@Model.Album.Grupo.Nome</span>
                            }
                            else if (Model.Album.Solista != null)
                            {
                                <span>@Model.Album.Solista.Nome</span>
                            }
                        </p>
                        <div class="d-flex gap-2">
                            <span class="badge-neon-pink">@Model.Album.Tipo</span> <!-- tipo do album -->
                            <span class="badge-neon-purple">@Model.Album.Edicao</span> <!-- edicao do album -->
                        </div>
                        <small class="text-secondary mt-1 d-block">
                            @Model.Album.DataLancamento.ToString("dd/MM/yyyy") • <!-- data de lancamento formatada -->
                            @(Model.Album.Musicas?.Count ?? 0) músicas <!-- numero de musicas -->
                        </small>
                    </div>
                </div>

                <!-- formulario de confirmacao de eliminacao -->
                <form method="post">
                    <input type="hidden" asp-for="Album.Id" /> <!-- campo escondido para o id -->
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger rounded-pill px-4">Confirmar Eliminação</button> <!-- botao de confirmacao -->
                        <a asp-page="./Details" asp-route-id="@Model.Album.Id" class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a> <!-- volta para os detalhes -->
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>