@page
@model K_Shelf.Pages.Albuns.CreateModel
@{
    ViewData["Title"] = "Adicionar Álbum";
}

<div class="container py-4 animate-fade-in-up">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-panel p-4 shadow-sm">
                <div class="d-flex align-items-center mb-4">
                    <span class="fs-1 me-3">📀</span>
                    <div>
                        <h2 class="fw-bold mb-0">Adicionar Álbum</h2>
                        <p class="text-secondary mb-0">Preencha os dados do novo álbum</p>
                    </div>
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>

                    <!-- Título (obrigatório) -->
                    <div class="mb-3">
                        <label asp-for="Album.Titulo" class="form-label fw-bold">
                            Título <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Album.Titulo" class="form-control search-input-kpop" placeholder="Ex: Map of the Soul: 7" />
                        <span asp-validation-for="Album.Titulo" class="text-danger small"></span>
                    </div>

                    <!-- Data de Lançamento (obrigatório) -->
                    <div class="mb-3">
                        <label asp-for="Album.DataLancamento" class="form-label fw-bold">
                            Data de Lançamento <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Album.DataLancamento" type="date" class="form-control search-input-kpop" />
                        <span asp-validation-for="Album.DataLancamento" class="text-danger small"></span>
                    </div>

                    <!-- URL da Capa (obrigatório) -->
                    <div class="mb-3">
                        <label asp-for="Album.CapaUrl" class="form-label fw-bold">
                            URL da Capa <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Album.CapaUrl" class="form-control search-input-kpop" placeholder="https://..." />
                        <span asp-validation-for="Album.CapaUrl" class="text-danger small"></span>
                    </div>

                    <!-- Tipo de Álbum (obrigatório) -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Album.Tipo" class="form-label fw-bold">
                                Tipo de Álbum <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Album.Tipo" class="form-select search-input-kpop"
                                    asp-items="Html.GetEnumSelectList<K_Shelf.Models.Album.TipoAlbum>()">
                            </select>
                            <span asp-validation-for="Album.Tipo" class="text-danger small"></span>
                        </div>

                        <!-- Edição (opcional) -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Album.Edicao" class="form-label fw-bold">Edição</label>
                            <select asp-for="Album.Edicao" class="form-select search-input-kpop"
                                    asp-items="Html.GetEnumSelectList<K_Shelf.Models.Album.EdicaoAlbum>()">
                            </select>
                            <span asp-validation-for="Album.Edicao" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Artista: Grupo ou Solista -->
                    <div class="bg-light rounded-3 p-3 mb-4">
                        <h6 class="fw-bold mb-3">🎤 Artista</h6>
                        <p class="text-secondary small mb-3">Associe o álbum a um <strong>Grupo</strong> ou a um <strong>Solista</strong> (não pode ser ambos).</p>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Album.GrupoId" class="form-label fw-bold"></label>
                                <div class="d-flex gap-2">
                                    <select asp-for="Album.GrupoId" class="form-select search-input-kpop"
                                            asp-items="Model.GruposSelectList">
                                        <option value="">-- Nenhum Grupo --</option>
                                    </select>
                                    <button type="button" class="btn btn-outline-primary btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalCriarGrupo"
                                            onclick="carregarModalGrupo()">
                                        ➕
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Album.SolistaId" class="form-label fw-bold"></label>
                                <div class="d-flex gap-2">
                                    <select asp-for="Album.SolistaId" class="form-select search-input-kpop"
                                            asp-items="Model.SolistasSelectList">
                                        <option value="">-- Nenhum Solista --</option>
                                    </select>
                                    <button type="button" class="btn btn-outline-primary btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalCriarSolista"
                                            onclick="carregarModalSolista()">
                                        ➕
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-kpop px-4">💾 Guardar</button>
                        <a asp-page="./Index" class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a>
                    </div>
                </form>

                <!-- ============================================================
     MODAL: CRIAR GRUPO
     ============================================================ -->
                <div class="modal fade" id="modalCriarGrupo" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content glass-panel border-0">
                            <div class="modal-header border-0">
                                <h5 class="modal-title fw-bold">👥 Criar Novo Grupo</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body" id="conteudoModalGrupo">
                                <div class="text-center py-4">
                                    <div class="spinner-border text-kpop" role="status">
                                        <span class="visually-hidden">A carregar...</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="modalCriarSolista" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content glass-panel border-0">
                            <div class="modal-header border-0">
                                <h5 class="modal-title fw-bold">🎤 Criar Novo Solista</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body" id="conteudoModalSolista">
                                <div class="text-center py-4">
                                    <div class="spinner-border text-kpop" role="status">
                                        <span class="visually-hidden">A carregar...</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Impede selecionar Grupo e Solista ao mesmo tempo
        const grupoSelect = document.getElementById('Album_GrupoId');
        const solistaSelect = document.getElementById('Album_SolistaId');

        grupoSelect.addEventListener('change', function () {
            if (this.value) solistaSelect.value = '';
        });

        solistaSelect.addEventListener('change', function () {
            if (this.value) grupoSelect.value = '';
        });


        // ============================================================
                // CARREGAR MODAL - GRUPO
                // ============================================================
                function carregarModalGrupo() {
                    fetch('/Grupos/Create')
                        .then(response => response.text())
                        .then(html => {
                            document.getElementById('conteudoModalGrupo').innerHTML = html;
                            const form = document.querySelector('#conteudoModalGrupo form');
                            if (form) {
                                form.addEventListener('submit', function(e) {
                                    e.preventDefault();
                                    const formData = new FormData(this);
                                    fetch('/Grupos/Create', {
                                        method: 'POST',
                                        body: formData
                                    })
                                    .then(response => response.text())
                                    .then(result => {
                                        if (result.includes('alert-danger')) {
                                            document.getElementById('conteudoModalGrupo').innerHTML = result;
                                        } else {
                                            bootstrap.Modal.getInstance(document.getElementById('modalCriarGrupo')).hide();
                                            location.reload();
                                        }
                                    });
                                });
                            }
                        });
                }

                // ============================================================
                // CARREGAR MODAL - SOLISTA
                // ============================================================
                function carregarModalSolista() {
                    fetch('/Solistas/Create')
                        .then(response => response.text())
                        .then(html => {
                            document.getElementById('conteudoModalSolista').innerHTML = html;
                            const form = document.querySelector('#conteudoModalSolista form');
                            if (form) {
                                form.addEventListener('submit', function(e) {
                                    e.preventDefault();
                                    const formData = new FormData(this);
                                    fetch('/Solistas/Create', {
                                        method: 'POST',
                                        body: formData
                                    })
                                    .then(response => response.text())
                                    .then(result => {
                                        if (result.includes('alert-danger')) {
                                            document.getElementById('conteudoModalSolista').innerHTML = result;
                                        } else {
                                            bootstrap.Modal.getInstance(document.getElementById('modalCriarSolista')).hide();
                                            location.reload();
                                        }
                                    });
                                });
                            }
                        });
                }

                // ============================================================
                // FECHAR MODAL AO CLICAR FORA
                // ============================================================
                document.addEventListener('DOMContentLoaded', function() {
                    const modals = document.querySelectorAll('.modal');
                    modals.forEach(modal => {
                        modal.addEventListener('hidden.bs.modal', function() {
                            if (this.id === 'modalCriarGrupo') {
                                document.getElementById('conteudoModalGrupo').innerHTML = `
                                    <div class="text-center py-4">
                                        <div class="spinner-border text-kpop" role="status">
                                            <span class="visually-hidden">A carregar...</span>
                                        </div>
                                    </div>
                                `;
                            } else if (this.id === 'modalCriarSolista') {
                                document.getElementById('conteudoModalSolista').innerHTML = `
                                    <div class="text-center py-4">
                                        <div class="spinner-border text-kpop" role="status">
                                            <span class="visually-hidden">A carregar...</span>
                                        </div>
                                    </div>
                                `;
                            }
                        });
                    });
                });
    </script>
}
