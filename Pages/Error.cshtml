@page
@model ErrorModel
@{
    ViewData["Title"] = Model.ErrorTitle;
}

<div class="container py-5 animate-fade-in-up">
    <div class="row justify-content-center text-center">
        <div class="col-lg-6 col-md-8">
            <div class="glass-panel p-5 shadow-lg border-0 rounded-4">
                <span class="display-1 mb-4 d-block" style="filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));">@Model.ErrorEmoji</span>
                
                <h1 class="fw-bold mb-3 text-dark">@Model.ErrorTitle</h1>
                <p class="lead text-secondary mb-4 fs-5">@Model.ErrorMessage</p>
                
                <hr class="my-4 opacity-25" style="border-color: var(--kpop-pink);" />
                
                @if (Model.ShowRequestId)
                {
                    <div class="bg-light p-2 rounded-3 mb-4 border" style="border-color: rgba(0,0,0,0.05) !important;">
                        <small class="text-secondary font-monospace">
                            <strong>ID do Pedido:</strong> @Model.RequestId
                        </small>
                    </div>
                }
                
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a asp-page="/Index" class="btn btn-kpop rounded-pill px-4 py-2 shadow-sm">
                        🏠 Ir para o Início
                    </a>
                    <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4 py-2">
                        ← Voltar Atrás
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
