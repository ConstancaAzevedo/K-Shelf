@page
@model ErrorModel
@{
    ViewData["Title"] = Model.ErrorTitle;
}

<div class="container py-5 animate-fade-in-up">
    <div class="row justify-content-center text-center">
        <div class="col-lg-6 col-md-8">
            <!-- painel principal com efeito glassmorphism -->
            <div class="glass-panel p-5 shadow-lg border-0 rounded-4 error-page">
                <!-- icone de erro (imagem) -->
                <img src="~/imagens/error-icon.png" alt="Erro" class="mb-4 error-icon-img"
                     style="width: 80px; height: 80px; object-fit: contain;"
                     onerror="this.src='~/imagens/error-icon.png'" /> <!-- fallback se a imagem nao carregar -->
                <!-- titulo do erro -->
                <h1 class="fw-bold mb-3 text-dark">@Model.ErrorTitle</h1>

                <!-- mensagem de erro -->
                <p class="lead text-secondary mb-3 fs-5">@Model.ErrorMessage</p>

                <!-- sugestao para resolver o erro -->
                <p class="text-muted mb-4 small">
                    <span class="fw-bold">Sugestão:</span> @Model.ErrorSuggestion
                </p>

                <hr class="my-4 opacity-25" style="border-color: var(--kpop-pink);" />

                <!-- id do pedido (para debug) -->
                @if (Model.ShowRequestId)
                {
                    <div class="bg-light p-2 rounded-3 mb-4 border" style="border-color: rgba(0,0,0,0.05) !important;">
                        <small class="text-secondary font-monospace">
                            <strong>ID do Pedido:</strong> @Model.RequestId
                        </small>
                    </div>
                }

                <!-- botoes de acao -->
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a asp-page="/Index" class="btn btn-kpop rounded-pill px-4 py-2 shadow-sm d-flex align-items-center gap-2">
                        <!-- icone de casa -->
                        <img src="~/imagens/casa.png" alt="Casa" style="width: 20px; height: 20px; object-fit: contain;" />
                        Ir para o Início
                    </a>
                    <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4 py-2 d-flex align-items-center gap-2">
                        <!-- icone de voltar -->
                        <img src="~/imagens/back.png" alt="Voltar" style="width: 20px; height: 20px; object-fit: contain;" />
                        Voltar Atrás
                    </a>
                </div>

                <!-- contacto de suporte -->
                <div class="mt-4 pt-3 border-top" style="border-color: rgba(0,0,0,0.05) !important;">
                    <p class="text-muted small mb-0 d-flex align-items-center justify-content-center gap-2">
                        <!-- icone de email -->
                        <img src="~/imagens/email.png" alt="Email" style="width: 16px; height: 16px; object-fit: contain;" />
                        Se o problema persistir, contacte o suporte em
                        <a href="mailto:admin@kshelf.com" style="color: var(--kpop-pink); text-decoration: none; font-weight: 500;">
                            admin@kshelf.com
                        </a>
                    </p>
                </div>

                <!-- link extra para voltar ao inicio -->
                <div class="mt-3">
                    <a asp-page="/Index" class="text-decoration-none" style="color: var(--kpop-pink); font-size: 0.9rem;">
                        ← Voltar à página inicial
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- scripts do lado do cliente -->
@section Scripts {
    <style>
        /* estilos para a pagina de erro */
        .error-page.glass-panel {
            background: rgba(255, 255, 255, 0.92) !important;
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 20px !important;
        }

        /* animacao suave para o icone */
        .error-icon-img {
            animation: floatError 3s ease-in-out infinite;
        }

        @keyframes floatError {
            0%, 100% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        /* imagens nos botoes */
        .btn img {
            transition: transform 0.2s ease;
        }

        .btn:hover img {
            transform: scale(1.1);
        }
    </style>
}