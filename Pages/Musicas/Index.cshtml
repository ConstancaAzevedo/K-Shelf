@page
@model K_Shelf.Pages.Musicas.IndexModel
@{
    ViewData["Title"] = "Gerir Músicas";
}

<div class="container py-4 animate-fade-in-up">
    <!-- cabecalho da pagina -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-4 fw-bold">🎵 Gerir Músicas</h1>
            <p class="text-secondary lead">Lista de todas as músicas do sistema</p>
        </div>
        <!-- botao para adicionar uma nova musica -->
        <a asp-page="./Create" class="btn btn-kpop rounded-pill">➕ Adicionar Música</a>
    </div>

    <!-- mensagem de feedback (sucesso) -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- tabela de musicas -->
    <div class="glass-panel p-4 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <!-- cabecalho da tabela -->
                <thead class="table-light">
                    <tr>
                        <th>#</th> <!-- coluna do numero de ordem -->
                        <th>Título</th> <!-- coluna do titulo -->
                        <th>Álbum</th> <!-- coluna do album -->
                        <th>Duração</th> <!-- coluna da duracao -->
                        <th>Faixa</th> <!-- coluna do numero da faixa -->
                        <th>Title Track</th> <!-- coluna que indica se e title track -->
                        <th class="text-center">Ações</th> <!-- coluna de botoes -->
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Musicas.Any()) // verifica se existem musicas
                    {
                        int count = 1; // contador para numerar as linhas
                        @foreach (var musica in Model.Musicas) // percorre a lista de musicas
                        {
                            <tr>
                                <td>@count</td> <!-- numero da linha -->
                                <td><strong>@musica.Titulo</strong></td> <!-- titulo da musica -->
                                <td>@(musica.Album?.Titulo ?? "N/A")</td> <!-- nome do album ou N/A -->
                                <td>@musica.DuracaoFormatada</td> <!-- duracao formatada -->
                                <td>@musica.TrackNumber</td> <!-- numero da faixa -->
                                <td>
                                    @if (musica.IsTitleTrack)
                                    {
                                        <!-- badge para indicar que e title track -->
                                        <span class="badge-neon-pink">★ Title</span>
                                    }
                                    else
                                    {
                                        <!-- badge vazio para musicas que nao sao title track -->
                                        <span class="badge bg-secondary">-</span>
                                    }
                                </td>
                                <td>
                                    <!-- botoes de acao -->
                                    <div class="d-flex gap-1 justify-content-center">
                                        <a asp-page="./Edit" asp-route-id="@musica.Id" class="btn btn-sm btn-warning rounded-pill px-2 py-1">✏️</a> <!-- botao de editar -->
                                        <a asp-page="./Delete" asp-route-id="@musica.Id" class="btn btn-sm btn-outline-danger rounded-pill px-2 py-1">🗑️</a> <!-- botao de eliminar -->
                                    </div>
                                </td>
                            </tr>
                            count++; // incrementa o contador
                        }
                    }
                    else
                    {
                        <!-- mensagem quando nao ha musicas -->
                        <tr>
                            <td colspan="7" class="text-center py-4 text-secondary">Nenhuma música encontrada</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>