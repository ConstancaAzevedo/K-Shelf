@page
@model K_Shelf.Pages.Colecoes.IndexModel
@{
    ViewData["Title"] = "As Minhas Coleções";
}

<div class="container py-4 animate-fade-in-up">
    <!-- Cabeçalho -->
    <div class="row align-items-center mb-5">
        <div class="col-lg-7">
            <h1 class="title-kpop display-4 fw-bold">Estante de Coleções</h1>
            <p class="text-secondary lead">Organize a sua discografia física e digital de K-Pop numa estante virtual interativa.</p>
        </div>
        <div class="col-lg-5 text-lg-end mt-3 mt-lg-0">
            @if (Model.IsUserAuthenticated)
            {
                <a asp-page="./Create" class="btn btn-kpop btn-lg shadow-sm rounded-pill px-4 py-2 hover-elevate">
                    ➕ Criar Nova Coleção
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- BANNER DE CONVITE SE NÃO ESTIVER AUTENTICADO -->
    @if (!Model.IsUserAuthenticated)
    {
        <div class="glass-panel-dark p-5 mb-5 shadow-lg border-0 animate-fade-in-up">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <span class="fs-1">🔒</span>
                    <h2 class="fw-bold mt-2 text-white">Crie a sua própria Estante de K-Pop!</h2>
                    <p class="lead text-light mb-0 opacity-75">
                        Faça login ou registe-se para começar a adicionar os seus álbuns favoritos, acompanhar photocards e partilhar a sua estante com amigos.
                    </p>
                </div>
                <div class="col-md-4 text-md-end mt-4 mt-md-0">
                    <div class="d-flex flex-column gap-2">
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-light btn-lg rounded-pill fw-bold text-dark shadow-sm">
                            Iniciar Sessão
                        </a>
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-kpop btn-lg rounded-pill shadow-sm">
                            Criar Conta Grátis
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- CONTEÚDO PRINCIPAL (COLEÇÕES) -->
    <div>
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-dark mb-0">
                @(Model.IsUserAuthenticated ? "As Minhas Coleções Ativas" : "Exemplo de Estantes de Colecionadores")
            </h2>
            @if (!Model.IsUserAuthenticated)
            {
                <span class="badge bg-secondary text-white rounded-pill px-3 py-2">Modo Visualização (Demo)</span>
            }
        </div>

        @{
            var colecoesExibir = Model.IsUserAuthenticated ? Model.Colecoes : Model.MockColecoes;
        }

        @if (!colecoesExibir.Any())
        {
            <div class="text-center py-5 glass-panel shadow-sm">
                <span class="display-3">📚</span>
                <h3 class="mt-3 fw-bold">Não tem nenhuma coleção ativa</h3>
                <p class="text-secondary">Comece por criar uma nova estante para organizar os seus álbuns!</p>
                <a asp-page="./Create" class="btn btn-kpop mt-3">Criar Primeira Coleção</a>
            </div>
        }
        else
        {
            <!-- ESTANTE VIRTUAL (DESIGN PREMIUM) -->
            <div class="shelf-container shadow-sm mb-5">
                <div class="row row-cols-1 row-cols-md-2 g-4">
                    @foreach (var colecao in colecoesExibir)
                    {
                        <div class="col">
                            <div class="card collection-card glass-panel p-4 h-100 border-0 shadow-sm transition-all position-relative" style="background: rgba(255,255,255,0.85);">
                                <!-- MOSAICO TRIDIMENSIONAL DE ÁLBUNS -->
                                <div class="mini-album-pile">
                                    @if (colecao.AlbumColecoes != null && colecao.AlbumColecoes.Any())
                                    {
                                        var count = 0;
                                        @foreach (var ac in colecao.AlbumColecoes.Take(3))
                                        {
                                            <img src="@(ac.Album?.CapaUrl ?? "https://images.unsplash.com/photo-1614613535308-eb5fbd3d2c17?q=80&w=500")" class="mini-cover" alt="Capa" />
                                            count++;
                                        }
                                        @for (var i = count; i < 3; i++)
                                        {
                                            <div class="mini-cover d-flex align-items-center justify-content-center text-white" style="background: linear-gradient(135deg, var(--kpop-pink), var(--kpop-purple)); font-size: 1.5rem;">
                                                💿
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <!-- Sem álbuns -->
                                        <div class="mini-cover d-flex align-items-center justify-content-center text-white" style="background: #ccc; font-size: 1.5rem; transform: translateX(-25px) rotate(-10deg);">💿</div>
                                        <div class="mini-cover d-flex align-items-center justify-content-center text-white" style="background: #ddd; font-size: 1.5rem; translateY(-5px);">💿</div>
                                        <div class="mini-cover d-flex align-items-center justify-content-center text-white" style="background: #bbb; font-size: 1.5rem; transform: translateX(25px) rotate(10deg);">💿</div>
                                    }
                                </div>

                                <!-- Detalhes da Coleção -->
                                <div class="text-center mt-3">
                                    <h3 class="fw-bold fs-4 text-dark mb-1">@colecao.Nome</h3>
                                    <p class="text-secondary small mb-3 text-truncate-2" style="height: 40px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                        @(colecao.Descricao ?? "Nenhuma descrição adicionada para esta coleção.")
                                    </p>
                                </div>

                                <!-- Status / Stats da Coleção -->
                                <div class="bg-light rounded-3 p-3 my-3">
                                    <div class="d-flex justify-content-between text-secondary mb-1" style="font-size: 0.85rem;">
                                        <span>Total de Álbuns:</span>
                                        <strong class="text-dark">@(colecao.AlbumColecoes?.Count ?? 0) álbuns</strong>
                                    </div>
                                    <!-- Barra de progresso fictícia de preenchimento de estante -->
                                    <div class="progress" style="height: 6px;">
                                        @{
                                            var numAlbuns = colecao.AlbumColecoes?.Count ?? 0;
                                            var progress = Math.Min(numAlbuns * 10, 100);
                                            if (progress == 0) progress = 15; // Mínimo visual
                                        }
                                        <div class="progress-bar" role="progressbar" style="width: @(progress)%; background: linear-gradient(135deg, var(--kpop-pink), var(--kpop-purple));" aria-valuenow="@progress" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <div class="d-flex justify-content-between mt-1 text-secondary" style="font-size: 0.75rem;">
                                        <span>Estante de Colecionador</span>
                                        <span>@progress% Cheia</span>
                                    </div>
                                </div>

                                <!-- Rodapé do Cartão -->
                                <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top gap-2">
                                    <span class="text-secondary small">
                                        📅 @colecao.DataCriacao.ToString("dd/MM/yyyy")
                                    </span>
                                    <div class="d-flex gap-1">
                                        <a asp-page="./Details" asp-route-id="@colecao.Id" class="btn btn-sm btn-kpop rounded-pill px-3 py-1">
                                            🔍 Ver Estante
                                        </a>
                                        @if (Model.IsUserAuthenticated)
                                        {
                                            <a asp-page="./Edit" asp-route-id="@colecao.Id" class="btn btn-sm btn-warning rounded-pill px-2 py-1">✏️</a>
                                            <a asp-page="./Delete" asp-route-id="@colecao.Id" class="btn btn-sm btn-outline-danger rounded-pill px-2 py-1">🗑️</a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Efeito Estante de Madeira Virtual -->
                <div class="shelf-row mt-4"></div>
            </div>
        }
    </div>
</div>
