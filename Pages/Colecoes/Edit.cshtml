@page
@model K_Shelf.Pages.Colecoes.EditModel
@{
    ViewData["Title"] = "Editar Coleção";
}

<div class="container py-4 animate-fade-in-up">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="glass-panel p-4 shadow-sm">
                <div class="d-flex align-items-center mb-4">
                    <span class="fs-1 me-3">✏️</span>
                    <div>
                        <h2 class="fw-bold mb-0">Editar Coleção</h2>
                        <p class="text-secondary mb-0">@Model.Colecao.Nome</p>
                    </div>
                </div>

                <form method="post">
                    <input type="hidden" asp-for="Colecao.Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>

                    <div class="mb-3">
                        <label asp-for="Colecao.Nome" class="form-label fw-bold"></label>
                        <input asp-for="Colecao.Nome" class="form-control search-input-kpop" />
                        <span asp-validation-for="Colecao.Nome" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Colecao.Descricao" class="form-label fw-bold"></label>
                        <textarea asp-for="Colecao.Descricao" class="form-control search-input-kpop" rows="3"></textarea>
                        <span asp-validation-for="Colecao.Descricao" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-kpop px-4">💾 Guardar Alterações</button>
                        <a asp-page="./Details" asp-route-id="@Model.Colecao.Id"
                           class="btn btn-outline-secondary rounded-pill px-4">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
