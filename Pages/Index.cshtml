@page
@model IndexModel
@{
    ViewData["Title"] = "K-Shelf - Coleção de Kpop";
}

<div class="text-center">
    <!-- Banner principal -->
    <div class="hero-banner">
        <div class="col-md-8 mx-auto">
            <!-- Logo -->
            <img src="~/imagens/logosemfundo.png" alt="K-Shelf Logo" style="max-height: 200px;" />
            <!-- Título da página principal -->
            <h1 class="title-kpop display-1">K-Shelf</h1>
            <h2 class="display-6 fw-bold text-secondary">Plataforma de Gestão de Coleções de Kpop</h2>
            <p class="lead mb-4 mt-4">
                Organize, descubra e partilhe a sua coleção de álbuns de Kpop de forma simples e intuitiva
            </p>
            <div class="d-flex gap-3 justify-content-center">
                <a class="btn btn-kpop btn-lg" asp-page="/Albuns/Index">Explorar Álbuns</a>
                <a class="btn btn-kpop btn-lg" asp-page="/Artistas/Index">Ver Artistas</a>
            </div>
        </div>
    </div>

    <!-- Características -->
    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card card-kpop h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="display-1">📀</div>
                    <h3 class="card-title mt-3">Gerir Coleções</h3>
                    <p class="card-text">Crie coleções personalizadas com os seus álbuns favoritos</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-kpop h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="display-1">🎤</div>
                    <h3 class="card-title mt-3">Explorar Artistas</h3>
                    <p class="card-text">Descubra artistas de Kpop, veja os seus álbuns e informações detalhadas</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-kpop h-100 shadow-sm">
                <div class="card-body text-center">
                    <div class="display-1">⚡</div>
                    <h3 class="card-title mt-3">Tempo Real</h3>
                    <p class="card-text">Receba notificações ao vivo quando novos álbuns são adicionados</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Estatísticas -->
    <div class="row mt-5" style="background: linear-gradient(135deg, #ff6b9d, #9b59b6); color: white; border-radius: 20px; padding: 2rem;">
        <div class="col-md-4 text-center">
            <h2 class="display-4 fw-bold" id="artistasCount">0+</h2>
            <p class="lead">Artistas</p>
        </div>
        <div class="col-md-4 text-center">
            <h2 class="display-4 fw-bold" id="albunsCount">0+</h2>
            <p class="lead">Álbuns</p>
        </div>
        <div class="col-md-4 text-center">
            <h2 class="display-4 fw-bold" id="colecoesCount">0+</h2>
            <p class="lead">Coleções</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Atualizar estatísticas com valores do servidor
        document.getElementById('artistasCount').innerText = '@Model.ArtistasCount';
        document.getElementById('albunsCount').innerText = '@Model.AlbunsCount';
        document.getElementById('colecoesCount').innerText = '@Model.ColecoesCount';
    </script>
}