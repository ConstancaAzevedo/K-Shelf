@page
@model K_Shelf.Pages.Admin.Cargos.IndexModel
@{
    ViewData["Title"] = "Gestão de Cargos - Admin";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container py-4 animate-fade-in-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-4 fw-bold">Gestão de Cargos</h1>
            <p class="text-secondary lead">Gerir cargos e permissões do sistema</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-page="/Admin/Dashboard" class="btn btn-outline-secondary rounded-pill">
                ← Voltar ao Dashboard
            </a>
            <button type="button" class="btn btn-kpop rounded-pill" data-bs-toggle="modal" data-bs-target="#createRoleModal">
                Criar Cargo
            </button>
        </div>
    </div>

    <!-- Mensagens de Feedback -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 animate-fade-in-up" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 animate-fade-in-up" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Tabela de Cargos -->
    <div class="glass-panel p-4 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nome do Cargo</th>
                        <th>Utilizadores com este Cargo</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Roles != null && Model.Roles.Any())
                    {
                        @foreach (var role in Model.Roles)
                        {
                            <tr>
                                <td>
                                    <strong>
                                        @if (role.Name == "Admin")
                                        {
                                            <span>🛡️</span>
                                        }
                                        else if (role.Name == "User")
                                        {
                                            <span>👤</span>
                                        }
                                        else
                                        {
                                            <span>🔑</span>
                                        }
                                        @role.Name
                                    </strong>
                                </td>
                                <td>
                                    <span class="badge bg-secondary rounded-pill">@role.UserCount</span>
                                    @if (role.UserCount > 0)
                                    {
                                        <span class="text-secondary small ms-2">utilizador(es)</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1 justify-content-center">
                                        <!-- Ver utilizadores com este cargo -->
                                        <a asp-page="./Details" asp-route-id="@role.Id"
                                           class="btn btn-sm btn-outline-info" title="Ver utilizadores">
                                            👥
                                        </a>

                                        <!-- Editar (apenas para cargos não padrão) -->
                                        @if (role.Name != "Admin" && role.Name != "User")
                                        {
                                            <a asp-page="./Edit" asp-route-id="@role.Id"
                                               class="btn btn-sm btn-outline-warning" title="Editar cargo">
                                                ✏️
                                            </a>

                                            <form method="post" asp-page-handler="Delete" asp-route-id="@role.Id"
                                                  onsubmit="return confirmarEliminacao('@role.Name')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar cargo">
                                                    🗑️
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-secondary small">(Cargo padrão)</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4">
                                <span class="display-4">📭</span>
                                <p class="text-secondary mt-2">Nenhum cargo encontrado.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal: Criar Cargo -->
<div class="modal fade" id="createRoleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content glass-panel border-0">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Criar Novo Cargo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Create">
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label asp-for="NewRoleName" class="form-label fw-bold">Nome do Cargo</label>
                        <input asp-for="NewRoleName" class="form-control" placeholder="Ex: Moderador" />
                        <span asp-validation-for="NewRoleName" class="text-danger"></span>
                        <small class="text-muted">O nome deve ter entre 3 e 50 caracteres.</small>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-kpop rounded-pill">Criar Cargo</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function confirmarEliminacao(nomeCargo) {
            return confirm('Tem a certeza que pretende eliminar o cargo "' + nomeCargo + '"?');
        }
    </script>
}