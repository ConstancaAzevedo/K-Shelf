@page
@model K_Shelf.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Dashboard - Administração";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container py-4 animate-fade-in-up">
    <!-- Cabeçalho -->
    <div class="row align-items-center mb-4">
        <div class="col">
            <h1 class="display-4 fw-bold">Dashboard</h1>
            <p class="text-secondary lead">Visão geral do sistema K-Shelf</p>
        </div>
        <div class="col-auto">
            <span class="badge bg-success rounded-pill px-3 py-2 fs-6">
                🟢 Sistema Online
            </span>
        </div>
    </div>

    <!-- Estatísticas -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="glass-panel p-4 text-center shadow-sm hover-elevate">
                <div class="display-4 fw-bold" style="color: var(--kpop-pink);">@Model.TotalUsers</div>
                <p class="text-secondary mb-0">Utilizadores</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-panel p-4 text-center shadow-sm hover-elevate">
                <div class="display-4 fw-bold" style="color: var(--kpop-purple);">@Model.TotalArtistas</div>
                <p class="text-secondary mb-0">Artistas</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-panel p-4 text-center shadow-sm hover-elevate">
                <div class="display-4 fw-bold" style="color: #f39c12;">@Model.TotalAlbuns</div>
                <p class="text-secondary mb-0">Álbuns</p>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 col-12">
            <div class="glass-panel p-4 text-center shadow-sm hover-elevate">
                <div class="display-4 fw-bold" style="color: #e74c3c;">@Model.TotalPhotocards</div>
                <p class="text-secondary mb-0">Photocards</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-panel p-4 text-center shadow-sm hover-elevate">
                <div class="display-4 fw-bold" style="color: #2ecc71;">@Model.TotalColecoes</div>
                <p class="text-secondary mb-0">Coleções</p>
            </div>
        </div>
    </div>

    <!-- Detalhes adicionais -->
    <div class="row g-4">
        <!-- Utilizadores por Role -->
        <div class="col-md-6">
            <div class="glass-panel p-4 shadow-sm">
                <h5 class="fw-bold mb-3">Utilizadores por Role</h5>
                <div class="list-group list-group-flush">
                    @foreach (var role in Model.UsersByRole)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center bg-transparent border-0 px-0">
                            <span>
                                @if (role.RoleName == "Admin")
                                {
                                    <span class="badge bg-danger me-2">🛡️</span>
                                }
                                else
                                {
                                    <span class="badge bg-info me-2">👤</span>
                                }
                                @role.RoleName
                            </span>
                            <span class="badge bg-secondary rounded-pill">@role.Count</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Atividades Recentes -->
        <div class="col-md-6">
            <div class="glass-panel p-4 shadow-sm">
                <h5 class="fw-bold mb-3">Atividades Recentes</h5>
                @if (Model.RecentActivities.Any())
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var activity in Model.RecentActivities)
                        {
                            <li class="d-flex align-items-center gap-3 py-2 border-bottom border-light">
                                <span class="fs-5">@activity.Icon</span>
                                <div class="flex-grow-1">
                                    <p class="mb-0 fw-semibold">@activity.Description</p>
                                    <small class="text-secondary">@activity.TimeAgo</small>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-secondary text-center py-3">Nenhuma atividade recente.</p>
                }
            </div>
        </div>
    </div>

    <!-- Links Rápidos -->
    <div class="row g-4 mt-3">
        <div class="col-12">
            <div class="glass-panel p-4 shadow-sm">
                <h5 class="fw-bold mb-3">Acessos Rápidos</h5>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-page="/Artistas/Index" class="btn btn-outline-primary rounded-pill px-4">
                        Gerir Artistas
                    </a>
                    <a asp-page="/Grupos/Index" class="btn btn-outline-primary rounded-pill px-4">
                        Gerir Grupos
                    </a>
                    <a asp-page="/Solistas/Index" class="btn btn-outline-primary rounded-pill px-4">
                        Gerir Solistas
                    </a>
                    <a asp-page="/Albuns/Index" class="btn btn-outline-primary rounded-pill px-4">
                        Gerir Álbuns
                    </a>
                    <a asp-page="/Musicas/Index" class="btn btn-outline-primary rounded-pill px-4">
                        Gerir Músicas
                    </a>
                    <a asp-page="/Colecoes/Index" class="btn btn-outline-primary rounded-pill px-4">
                        Gerir Coleções
                    </a>
                    <a asp-page="/Admin/Users/Index" class="btn btn-outline-primary rounded-pill px-4">
                        Gerir Utilizadores
                    </a>
                    <a asp-page="/Photocards/Index" class="btn btn-outline-primary rounded-pill px-4">
                        Gerir Photocards
                    </a>
                    <a asp-page="/Admin/Roles/Index" class="btn btn-outline-primary rounded-pill px-4">
                        Gerir Cargos
                    </a>
                    <a asp-page="/MakeMeAdmin" class="btn btn-outline-warning rounded-pill px-4">
                        Tornar-me Admin
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>