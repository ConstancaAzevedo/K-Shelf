@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/login.css" />


<div class="login-container">
    <div class="header">
        <h2>K-Shelf</h2>
        <p>Bem-vindo</p>
    </div>

    <div class="content">
        <div class="info-box">
            Use uma conta local para fazer login
        </div>


        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="nome@exemplo.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="checkbox-group">
                <label class="checkbox-label">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                </label>
                <a id="forgot-password" asp-page="./ForgotPassword" class="forgot-link">Esqueceu a password?</a>
            </div>

            <button id="login-submit" type="submit" class="login-btn">Entrar</button>

            <div class="links">
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Login de um utilizador existente</a>
                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Reenviar confirmação de email</a>
            </div>
        </form>

        @{
            if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="external-login">
                    <h3>Ou use outro serviço para entrar</h3>
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" name="provider" value="@provider.Name" title="Entrar usando a sua conta @provider.DisplayName">@provider.DisplayName</button>
                        }
                    </form>
                </div>
            }
        }
    </div>

    <div class="footer" style="margin-left: 20px; margin-bottom: 20px">
        © 2026 - <a href="#">K-Shelf</a> - <a href="#">Privacy</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}