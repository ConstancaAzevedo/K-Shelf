@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Alterar Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="profile-header mb-4">
    <h2 class="title-kpop fw-bold mb-2">Alterar Password</h2>
    <p class="text-secondary">Atualize a sua senha de segurança</p>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

@if (ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
        <strong>Atenção!</strong> Verifique os campos abaixo.
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form id="change-password-form" method="post" class="profile-form">
    <div asp-validation-summary="None" class="text-danger"></div>

    <!-- Password Anterior -->
    <div class="form-floating mb-3">
        <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Digite a sua password atual" />
        <label asp-for="Input.OldPassword" class="form-label">Password Atual</label>
        <span asp-validation-for="Input.OldPassword" class="text-danger small d-block mt-1"></span>
    </div>

    <!-- Nova Password -->
    <div class="form-floating mb-3">
        <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Digite a sua nova password" />
        <label asp-for="Input.NewPassword" class="form-label">Nova Password</label>
        <span asp-validation-for="Input.NewPassword" class="text-danger small d-block mt-1"></span>
    </div>

    <!-- Confirmar Password -->
    <div class="form-floating mb-4">
        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirme a sua nova password" />
        <label asp-for="Input.ConfirmPassword" class="form-label">Confirmar Password</label>
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small d-block mt-1"></span>
    </div>

    <!-- Botões -->
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-kpop btn-lg rounded-pill px-4 shadow-sm">
            Alterar Password
        </button>
        <a href="@Url.Page("/Index")" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
            Cancelar
        </a>
    </div>
</form>

<style>
    .profile-form {
        max-width: 500px;
    }

    .profile-form .form-floating label {
        color: var(--kpop-dark);
        font-weight: 500;
    }

    .profile-form .form-control {
        border-radius: 10px;
        border: 1px solid #ddd;
        padding: 1rem 0.75rem;
        transition: all 0.3s ease;
    }

    .profile-form .form-control:focus {
        border-color: var(--kpop-purple);
        box-shadow: 0 0 0 0.2rem rgba(155, 89, 182, 0.25);
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
